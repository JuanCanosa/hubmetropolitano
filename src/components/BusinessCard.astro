---
import type { Business } from '../utils/mockBusinesses';

interface Props {
  business: Business;
}

const { business } = Astro.props;
const previewServices = business.services.slice(0, 3);

const baseUrl =
  business.type === 'servicos-profissionais' ? `/servicos-profissionais/${business.slug}` :
  business.type === 'servicos-tecnicos'      ? `/servicos-tecnicos/${business.slug}` :
  business.type === 'gastronomia'            ? `/gastronomia/${business.slug}` :
  business.type === 'saude'                  ? `/saude/${business.slug}` :
  business.type === 'beleza'                 ? `/beleza/${business.slug}` :
  business.type === 'esporte'               ? `/esporte/${business.slug}` :
  `/digital/${business.slug}`;

const urgenciaLabel: Record<string, { label: string; color: string }> = {
  'sim-24h':       { label: '⚡ Urgência 24h',        color: 'bg-red-500 text-white' },
  'sim-comercial': { label: '✓ Atende urgências',     color: 'bg-amber-500 text-white' },
};
const urgencia = business.atendeUrgencia ? urgenciaLabel[business.atendeUrgencia] : null;

const whatsappUrl = business.whatsapp
  ? `https://wa.me/${business.whatsapp}?text=Olá!%20Vim%20pelo%20HubMetropolitano%20e%20gostaria%20de%20agendar.`
  : null;

// Destaque extra para categorias de agendamento
const isAgendamentoType = business.type === 'beleza' || business.type === 'saude' || business.type === 'esporte';
---

<a
  href={baseUrl}
  class="group flex flex-col bg-white rounded-2xl border border-hub-gelo shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
>
  <!-- Cover -->
  <div class="relative h-44 overflow-hidden bg-hub-pavao-profundo">
    <img
      src={business.cover}
      alt={business.title}
      loading="lazy"
      class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-hub-pavao-profundo/80 via-hub-pavao-profundo/20 to-transparent" />

    <!-- Category badge -->
    <span class="absolute top-3 right-3 bg-hub-cobre text-white text-xs font-head font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full">
      {business.category.split(' ')[0]}
    </span>

    <!-- Urgência badge (LT3) -->
    {urgencia && (
      <span class={`absolute top-3 left-3 text-xs font-body font-semibold px-2.5 py-1 rounded-full ${urgencia.color}`}>
        {urgencia.label}
      </span>
    )}

    <!-- Logo -->
    {business.logo ? (
      <img
        src={business.logo}
        alt={`Logo ${business.title}`}
        class="absolute bottom-3 left-4 w-10 h-10 rounded-full border-2 border-white object-cover bg-white shadow"
      />
    ) : (
      <div class="absolute bottom-3 left-4 w-10 h-10 rounded-full border-2 border-white bg-hub-pavao flex items-center justify-center shadow">
        <span class="text-white font-head font-bold text-sm">
          {business.title.charAt(0)}
        </span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <!-- Name + tagline -->
    <div>
      <h3 class="font-head font-bold text-hub-chumbo group-hover:text-hub-cobre transition-colors text-lg uppercase tracking-wide leading-tight">
        {business.title}
      </h3>
      <p class="font-body text-sm text-hub-chumbo/60 mt-0.5 leading-snug">
        {business.tagline}
      </p>
    </div>

    <!-- Location -->
    {business.location && (
      <div class="flex items-center gap-1.5 text-hub-chumbo/40 text-xs font-body">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
          <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
        </svg>
        {business.location}
      </div>
    )}

    <!-- O que Fazemos preview -->
    <div class="flex flex-wrap gap-1.5 mt-auto">
      {previewServices.map(s => (
        <span class="inline-flex items-center gap-1 bg-hub-gelo text-hub-chumbo/70 text-xs font-body px-2.5 py-1 rounded-full">
          <span>{s.icon}</span>
          <span>{s.name}</span>
        </span>
      ))}
      {business.services.length > 3 && (
        <span class="inline-flex items-center bg-hub-pavao-soft text-hub-pavao text-xs font-body px-2.5 py-1 rounded-full">
          +{business.services.length - 3}
        </span>
      )}
    </div>
  </div>

  <!-- Footer -->
  <div class={`px-5 pb-4 pt-0 flex items-center ${whatsappUrl ? 'justify-between gap-3' : ''}`}>
    <span class="inline-flex items-center gap-1.5 text-hub-cobre text-sm font-body group-hover:gap-3 transition-all shrink-0">
      Ver perfil completo
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </span>

    {whatsappUrl && (
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        onclick="event.stopPropagation()"
        class={`inline-flex items-center gap-1.5 text-xs font-body font-semibold px-3 py-2 rounded-full transition-all active:scale-95 shrink-0 ${
          isAgendamentoType
            ? 'bg-[#25D366] text-white hover:bg-[#1ebe5d]'
            : 'bg-hub-gelo text-hub-chumbo/70 hover:bg-[#25D366] hover:text-white'
        }`}
        aria-label="Agendar via WhatsApp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Agendar
      </a>
    )}
  </div>
</a>
