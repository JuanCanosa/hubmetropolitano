---
// Header Component
import Logo from './Logo.astro';

const user = Astro.locals.user ?? null;
const displayName = user
  ? ((user.user_metadata?.full_name as string) || user.email?.split('@')[0] || 'Usuário')
  : null;
const initials = displayName
  ? displayName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()
  : '';
---

<header class="bg-hub-pavao text-hub-gelo py-4 sticky top-0 z-50 shadow-md">
  <div class="container mx-auto px-4 lg:px-8 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="group hover:opacity-90 transition-opacity duration-300">
      <Logo size="md" variant="inverse" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8 font-head tracking-widest text-sm uppercase">
      <a href="/servicos/gastronomia" class="hover:text-hub-cobre transition-colors">Gastronomia</a>
      <a href="/servicos/saude-bem-estar" class="hover:text-hub-cobre transition-colors">Saúde</a>
      <a href="/servicos/esporte-lazer" class="hover:text-hub-cobre transition-colors">Esporte & Lazer</a>
      <a href="/servicos/profissionais-b2b" class="hover:text-hub-cobre transition-colors">Profissionais B2B</a>
      <a href="/servicos/tecnico-casa" class="hover:text-hub-cobre transition-colors">Técnicos & Casa</a>
      <a href="/servicos" class="hover:text-hub-cobre transition-colors">Serviços</a>
      <a href="/blog" class="hover:text-hub-cobre transition-colors">Blog</a>
      <a href="/contato" class="hover:text-hub-cobre transition-colors">Fale Conosco</a>
    </nav>

    <!-- Área direita: auth + CTA -->
    <div class="hidden md:flex items-center gap-3">
      {user ? (
        <>
          <!-- Avatar + nome -->
          <a href="/dashboard" class="flex items-center gap-2.5 group">
            <div class="w-8 h-8 rounded-full bg-hub-cobre flex items-center justify-center shrink-0">
              <span class="font-head font-bold text-white text-xs">{initials}</span>
            </div>
            <span class="font-head font-semibold uppercase tracking-wide text-xs text-hub-gelo/80 group-hover:text-hub-cobre transition-colors">
              {displayName}
            </span>
          </a>
          <!-- Sair -->
          <form method="POST" action="/api/auth/signout" class="contents">
            <button type="submit" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-gelo/50 hover:text-hub-gelo transition-colors px-1 py-1">
              Sair
            </button>
          </form>
          <!-- Anuncie -->
          <a href="/anuncie" class="bg-hub-cobre text-hub-gelo font-body font-bold py-2 px-5 rounded hover:bg-hub-cobre-luminoso transition-all shadow-sm hover:shadow-md text-sm">
            Anuncie
          </a>
        </>
      ) : (
        <>
          <!-- Entrar -->
          <a href="/login" class="font-head font-semibold uppercase tracking-widest text-sm text-hub-gelo/70 hover:text-hub-gelo transition-colors">
            Entrar
          </a>
          <!-- Anuncie -->
          <a href="/anuncie" class="bg-hub-cobre text-hub-gelo font-body font-bold py-2 px-6 rounded hover:bg-hub-cobre-luminoso transition-all shadow-sm hover:shadow-md">
            Anuncie
          </a>
        </>
      )}
    </div>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden text-hub-gelo hover:text-hub-cobre" aria-label="Abrir Menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-hub-pavao border-t border-hub-gelo/20">
    <div class="container mx-auto px-4 py-4 flex flex-col gap-1 font-head tracking-widest text-sm uppercase">
      <a href="/servicos/gastronomia" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Gastronomia</a>
      <a href="/servicos/saude-bem-estar" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Saúde & Bem-Estar</a>
      <a href="/servicos/esporte-lazer" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Esporte & Lazer</a>
      <a href="/servicos/profissionais-b2b" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Profissionais B2B</a>
      <a href="/servicos/tecnico-casa" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Técnicos & Casa</a>
      <a href="/servicos" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Serviços</a>
      <a href="/blog" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Blog</a>
      <a href="/contato" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Fale Conosco</a>

      {user ? (
        <>
          <a href="/dashboard" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-hub-cobre flex items-center justify-center shrink-0">
              <span class="font-head font-bold text-white text-[10px]">{initials}</span>
            </div>
            Dashboard
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="w-full text-left px-3 py-3 rounded-lg hover:bg-white/10 text-hub-gelo/60 hover:text-hub-gelo transition-colors">
              Sair
            </button>
          </form>
        </>
      ) : (
        <a href="/login" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">
          Entrar
        </a>
      )}

      <a href="/anuncie" class="mt-3 bg-hub-cobre text-hub-gelo font-body font-bold py-3 px-6 rounded text-center hover:bg-hub-cobre-luminoso transition-all">
        Anuncie
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Fecha ao clicar em um link
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
