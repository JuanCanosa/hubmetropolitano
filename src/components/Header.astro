---
// Header Component
import Logo from './Logo.astro';
---

<header class="bg-hub-pavao text-hub-gelo py-4 sticky top-0 z-50 shadow-md">
  <div class="container mx-auto px-4 lg:px-8 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="group hover:opacity-90 transition-opacity duration-300">
      <Logo size="md" variant="inverse" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8 font-head tracking-widest text-sm uppercase">
      <a href="/categoria/gastronomia" class="hover:text-hub-cobre transition-colors">Gastronomia</a>
      <a href="/categoria/saude" class="hover:text-hub-cobre transition-colors">Saúde</a>
      <a href="/categoria/imoveis" class="hover:text-hub-cobre transition-colors">Imóveis</a>
      <a href="/servicos" class="hover:text-hub-cobre transition-colors">Serviços</a>
      <a href="/blog" class="hover:text-hub-cobre transition-colors">Blog</a>
      <a href="/contato" class="hover:text-hub-cobre transition-colors">Fale Conosco</a>
    </nav>

    <!-- CTA Button -->
    <div class="hidden md:block">
      <a href="/anuncie" class="bg-hub-cobre text-hub-gelo font-body font-bold py-2 px-6 rounded hover:bg-opacity-90 transition-all shadow-sm hover:shadow-md">
        Anuncie
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden text-hub-gelo hover:text-hub-cobre" aria-label="Abrir Menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-hub-pavao border-t border-hub-gelo/20">
    <div class="container mx-auto px-4 py-4 flex flex-col gap-1 font-head tracking-widest text-sm uppercase">
      <a href="/categoria/gastronomia" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Gastronomia</a>
      <a href="/categoria/saude" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Saúde</a>
      <a href="/categoria/imoveis" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Imóveis</a>
      <a href="/servicos" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Serviços</a>
      <a href="/blog" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Blog</a>
      <a href="/contato" class="px-3 py-3 rounded-lg hover:bg-white/10 hover:text-hub-cobre transition-colors">Fale Conosco</a>
      <a href="/anuncie" class="mt-3 bg-hub-cobre text-hub-gelo font-body font-bold py-3 px-6 rounded text-center hover:bg-opacity-90 transition-all">
        Anuncie
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Fecha ao clicar em um link
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
