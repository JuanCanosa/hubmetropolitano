---
/**
 * Campos compartilhados do formulário de negócio (criação e edição).
 * O campo <form>, hidden inputs de imagem e <script> ficam na página pai.
 */
interface ServiceItem  { titulo: string; descricao: string; preco: string; }
interface TeamMember   { nome: string; especialidade: string; }
interface Horarios     { seg_sex?: string; sabado?: string; domingo?: string; }
interface ListaExtra   { label?: string; itens?: string[]; }

interface Props {
  biz?: {
    title?: string;
    slogan?: string;
    category_id?: number | null;
    location_id?: number | null;
    description?: string;
    cover_url?: string | null;
    logo_url?: string | null;
    features_json?: any;
    phone?: string | null;
    whatsapp?: string | null;
    email?: string | null;
    website?: string | null;
    address?: string | null;
  };
  categories: { id: number; name: string }[];
  locations:  { id: number; name: string }[];
  fieldErrors?: Record<string, string>;
}

const { biz, categories, locations, fieldErrors = {} } = Astro.props;

// Taxonomias
const TAXONOMIES = [
  { group: 'Serviços',    items: ['Aceita reservas', 'Delivery disponível', 'Atendimento domiciliar', 'Agendamento online'] },
  { group: 'Comodidades', items: ['Estacionamento', 'Wi-Fi gratuito', 'Acessibilidade', 'Pet friendly'] },
  { group: 'Ambiente',    items: ['Sofisticado', 'Executivo', 'Romântico', 'Familiar', 'Casual'] },
  { group: 'Pagamento',   items: ['Aceita cartão', 'Aceita PIX', 'Parcelamento disponível'] },
];

// Extrai dados do features_json existente
const fj           = (biz?.features_json as any) ?? {};
const currentTags  = (fj.tags ?? []) as string[];
const servicos     = (fj.servicos ?? [{ titulo:'', descricao:'', preco:'' }]) as ServiceItem[];
// Garante pelo menos 1 slot vazio
while (servicos.length < 1) servicos.push({ titulo:'', descricao:'', preco:'' });
const horarios     = (fj.horarios ?? {}) as Horarios;
const equipe       = (fj.equipe ?? []) as TeamMember[];
const listaExtra   = (fj.lista_extra ?? {}) as ListaExtra;
const listaItens   = listaExtra.itens?.join(', ') ?? '';

// Input base class
const inp = 'w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 text-sm';
---

<!-- ── Imagens ───────────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
  <div class="px-6 lg:px-8 pt-6 pb-2">
    <h3 class="text-hub-pavao text-base mb-1">Imagens</h3>
    <p class="font-body text-hub-chumbo/40 text-xs mb-5">Formatos aceitos: JPG, PNG, WEBP · Máx. 5 MB</p>
  </div>

  <!-- Cover -->
  <div class="px-6 lg:px-8 mb-5">
    <label class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-2 block">Foto de capa</label>
    <div id="cover-drop" class="relative w-full h-44 rounded-2xl border-2 border-dashed border-hub-gelo bg-hub-gelo/40 flex flex-col items-center justify-center cursor-pointer hover:border-hub-cobre/40 hover:bg-hub-cobre/5 transition-colors overflow-hidden">
      <img id="cover-preview" src={biz?.cover_url ?? ''} alt="" class={`absolute inset-0 w-full h-full object-cover ${biz?.cover_url ? '' : 'hidden'}`} />
      <div id="cover-placeholder" class={`flex flex-col items-center gap-2 text-center px-4 ${biz?.cover_url ? 'hidden' : ''}`}>
        <div class="w-10 h-10 rounded-xl bg-hub-pavao-soft flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-hub-pavao/50"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
        </div>
        <span class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/40">Clique para adicionar capa</span>
        <span class="font-body text-hub-chumbo/30 text-xs">Recomendado: 1200 × 400 px</span>
      </div>
      <button type="button" id="cover-remove" class={`absolute top-2 right-2 w-7 h-7 rounded-full bg-black/50 text-white items-center justify-center hover:bg-black/70 transition-colors z-10 ${biz?.cover_url ? 'flex' : 'hidden'}`}>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
      <input type="file" id="cover-file" accept="image/jpeg,image/jpg,image/png,image/webp" class="absolute inset-0 opacity-0 cursor-pointer" />
    </div>
    <p id="cover-error" class="font-body text-red-500 text-xs mt-1 hidden"></p>
  </div>

  <!-- Logo -->
  <div class="px-6 lg:px-8 pb-6">
    <label class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-2 block">Logo <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span></label>
    <div class="flex items-center gap-4">
      <div id="logo-drop" class="relative w-24 h-24 rounded-2xl border-2 border-dashed border-hub-gelo bg-hub-gelo/40 flex flex-col items-center justify-center cursor-pointer hover:border-hub-cobre/40 hover:bg-hub-cobre/5 transition-colors overflow-hidden shrink-0">
        <img id="logo-preview" src={biz?.logo_url ?? ''} alt="" class={`absolute inset-0 w-full h-full object-cover rounded-xl ${biz?.logo_url ? '' : 'hidden'}`} />
        <div id="logo-placeholder" class={`flex flex-col items-center gap-1 ${biz?.logo_url ? 'hidden' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-hub-pavao/30"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
        </div>
        <button type="button" id="logo-remove" class={`absolute top-1 right-1 w-5 h-5 rounded-full bg-black/50 text-white items-center justify-center hover:bg-black/70 transition-colors z-10 ${biz?.logo_url ? 'flex' : 'hidden'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-2.5 h-2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
        </button>
        <input type="file" id="logo-file" accept="image/jpeg,image/jpg,image/png,image/webp" class="absolute inset-0 opacity-0 cursor-pointer" />
      </div>
      <div>
        <p class="font-body text-hub-chumbo/50 text-sm">Clique para {biz?.logo_url ? 'trocar o' : 'adicionar o'} logo</p>
        <p class="font-body text-hub-chumbo/30 text-xs mt-0.5">Recomendado: 400 × 400 px</p>
      </div>
    </div>
    <p id="logo-error" class="font-body text-red-500 text-xs mt-1 hidden"></p>
  </div>
</div>

<!-- ── Identificação ──────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-5">Identificação</h3>
  <div class="flex flex-col gap-5">

    <div>
      <label for="title" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Nome do negócio <span class="text-hub-cobre">*</span></label>
      <input id="title" name="title" type="text" required value={biz?.title ?? ''} placeholder="Ex: Restaurante Mar Azul"
        class={`${inp} ${fieldErrors.title ? 'border-red-400' : 'border-hub-gelo'}`} />
      {fieldErrors.title && <p class="font-body text-red-500 text-xs mt-1">{fieldErrors.title}</p>}
    </div>

    <div>
      <label for="slogan" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Slogan / Tagline <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span></label>
      <input id="slogan" name="slogan" type="text" value={biz?.slogan ?? ''} placeholder="Ex: Sabor do mar direto pra você" class={inp} />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="category_id" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Categoria</label>
        <select id="category_id" name="category_id" class={`${inp} appearance-none`}>
          <option value="">Selecione...</option>
          {categories.map((c) => <option value={c.id} selected={biz?.category_id === c.id}>{c.name}</option>)}
        </select>
      </div>
      <div>
        <label for="location_id" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Localização / Empreendimento</label>
        <select id="location_id" name="location_id" class={`${inp} appearance-none`}>
          <option value="">Selecione...</option>
          {locations.map((l) => <option value={l.id} selected={biz?.location_id === l.id}>{l.name}</option>)}
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="tipo_servico" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Tipo de serviço <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span></label>
        <input id="tipo_servico" name="tipo_servico" type="text" value={fj.tipo_servico ?? ''} placeholder="Ex: Cafeterias & Padarias, Clínica Odontológica" class={inp} />
      </div>
      <div>
        <label for="faixa_preco" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Faixa de preço <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span></label>
        <input id="faixa_preco" name="faixa_preco" type="text" value={fj.faixa_preco ?? ''} placeholder="Ex: R$50 – R$350" class={inp} />
      </div>
    </div>

  </div>
</div>

<!-- ── Descrição ──────────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-5">Descrição</h3>
  <label for="description" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Sobre o negócio <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span></label>
  <textarea id="description" name="description" rows="5" placeholder="Descreva seu negócio, diferenciais, especialidades, anos de experiência..." class={`${inp} resize-none`}>{biz?.description ?? ''}</textarea>
</div>

<!-- ── Serviços / Cardápio ────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <div class="flex items-center justify-between mb-1">
    <h3 class="text-hub-pavao text-base">Serviços / Cardápio</h3>
    <span class="font-body text-hub-chumbo/30 text-xs">até 6 itens</span>
  </div>
  <p class="font-body text-hub-chumbo/40 text-xs mb-5">Liste os principais serviços, pratos ou produtos com preço</p>

  <div id="servicos-list" class="flex flex-col gap-4">
    {servicos.map((s, i) => (
      <div class="servico-item grid grid-cols-1 sm:grid-cols-[1fr_1fr_auto] gap-3 items-start bg-hub-gelo/40 rounded-xl p-4 border border-hub-gelo">
        <div class="sm:col-span-2">
          <input name={`servico_titulo_${i+1}`} type="text" value={s.titulo} placeholder={`Título do serviço ${i+1}`} class={inp} />
        </div>
        <div class="flex items-center gap-2 sm:row-start-1 sm:col-start-3">
          <input name={`servico_preco_${i+1}`} type="text" value={s.preco} placeholder="R$00" class={`${inp} sm:w-28`} />
          {i > 0 && (
            <button type="button" class="remove-servico shrink-0 w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 flex items-center justify-center transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
            </button>
          )}
        </div>
        <div class="sm:col-span-3">
          <input name={`servico_descricao_${i+1}`} type="text" value={s.descricao} placeholder="Descrição breve (opcional)" class={inp} />
        </div>
      </div>
    ))}
  </div>

  <button type="button" id="add-servico" class="mt-4 inline-flex items-center gap-2 font-head font-semibold uppercase tracking-wide text-xs text-hub-cobre hover:text-hub-cobre-luminoso transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
    Adicionar serviço
  </button>
</div>

<!-- ── Horários ───────────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-5">Horários de Funcionamento</h3>
  <div class="flex flex-col gap-4">
    <div class="flex items-center gap-3">
      <label class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 w-24 shrink-0">Seg – Sex</label>
      <input name="horario_seg_sex" type="text" value={horarios.seg_sex ?? ''} placeholder="Ex: 08h – 20h ou Fechado" class={`${inp} flex-1`} />
    </div>
    <div class="flex items-center gap-3">
      <label class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 w-24 shrink-0">Sábado</label>
      <input name="horario_sabado" type="text" value={horarios.sabado ?? ''} placeholder="Ex: 09h – 17h ou Fechado" class={`${inp} flex-1`} />
    </div>
    <div class="flex items-center gap-3">
      <label class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 w-24 shrink-0">Domingo</label>
      <input name="horario_domingo" type="text" value={horarios.domingo ?? ''} placeholder="Ex: 10h – 16h ou Fechado" class={`${inp} flex-1`} />
    </div>
  </div>
</div>

<!-- ── Equipe ─────────────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <div class="flex items-center justify-between mb-1">
    <h3 class="text-hub-pavao text-base">Equipe <span class="font-body normal-case font-normal text-hub-chumbo/30 text-sm">(opcional)</span></h3>
    <span class="font-body text-hub-chumbo/30 text-xs">até 4 membros</span>
  </div>
  <p class="font-body text-hub-chumbo/40 text-xs mb-5">Profissionais em destaque do seu negócio</p>

  <div id="equipe-list" class="flex flex-col gap-3">
    {equipe.length === 0
      ? (
        <div class="equipe-item grid grid-cols-1 sm:grid-cols-2 gap-3">
          <input name="equipe_nome_1" type="text" value="" placeholder="Nome do profissional" class={inp} />
          <input name="equipe_especialidade_1" type="text" value="" placeholder="Cargo / Especialidade" class={inp} />
        </div>
      )
      : equipe.map((m, i) => (
        <div class="equipe-item grid grid-cols-1 sm:grid-cols-[1fr_1fr_auto] gap-3 items-center">
          <input name={`equipe_nome_${i+1}`} type="text" value={m.nome} placeholder="Nome do profissional" class={inp} />
          <input name={`equipe_especialidade_${i+1}`} type="text" value={m.especialidade} placeholder="Cargo / Especialidade" class={inp} />
          {i > 0 && (
            <button type="button" class="remove-equipe w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 flex items-center justify-center transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
            </button>
          )}
        </div>
      ))
    }
  </div>

  <button type="button" id="add-equipe" class="mt-4 inline-flex items-center gap-2 font-head font-semibold uppercase tracking-wide text-xs text-hub-cobre hover:text-hub-cobre-luminoso transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
    Adicionar membro
  </button>
</div>

<!-- ── Lista Personalizada ───────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-1">Lista Personalizada <span class="font-body normal-case font-normal text-hub-chumbo/30 text-sm">(opcional)</span></h3>
  <p class="font-body text-hub-chumbo/40 text-xs mb-5">Use para especialidades, marcas atendidas, planos aceitos, setores, etc.</p>
  <div class="flex flex-col gap-4">
    <div>
      <label for="lista_extra_label" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Título da lista</label>
      <input id="lista_extra_label" name="lista_extra_label" type="text" value={listaExtra.label ?? ''} placeholder="Ex: Especialidades, Marcas atendidas, Planos aceitos..." class={inp} />
    </div>
    <div>
      <label for="lista_extra_itens" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Itens <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(separados por vírgula)</span></label>
      <input id="lista_extra_itens" name="lista_extra_itens" type="text" value={listaItens} placeholder="Ex: Implantodontia, Estética Dental, Ortodontia" class={inp} />
    </div>
  </div>
</div>

<!-- ── Informações Extras ─────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-1">Informações Adicionais <span class="font-body normal-case font-normal text-hub-chumbo/30 text-sm">(opcional)</span></h3>
  <p class="font-body text-hub-chumbo/40 text-xs mb-5">Preencha apenas os campos relevantes ao seu tipo de negócio</p>
  <div class="flex flex-col gap-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="areas_atendimento" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Áreas de atendimento</label>
        <input id="areas_atendimento" name="areas_atendimento" type="text" value={fj.areas_atendimento ?? ''} placeholder="Ex: Barra, Recreio, Jacarepaguá" class={inp} />
      </div>
      <div>
        <label for="tempo_resposta" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Tempo de resposta</label>
        <input id="tempo_resposta" name="tempo_resposta" type="text" value={fj.tempo_resposta ?? ''} placeholder="Ex: 24-48h, Imediato" class={inp} />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="garantia" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Garantia</label>
        <input id="garantia" name="garantia" type="text" value={fj.garantia ?? ''} placeholder="Ex: 6 meses em peças e serviço" class={inp} />
      </div>
      <div>
        <label for="registro_id" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Registro profissional</label>
        <input id="registro_id" name="registro_id" type="text" value={fj.registro_id ?? ''} placeholder="Ex: CRC/RJ-045231, CRM 12345" class={inp} />
      </div>
    </div>
    <div>
      <label for="clientes" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Clientes / Cases</label>
      <input id="clientes" name="clientes" type="text" value={fj.clientes ?? ''} placeholder="Ex: Mais de 120 empresas atendidas" class={inp} />
    </div>
  </div>
</div>

<!-- ── Características / Taxonomias ─────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-1">Características</h3>
  <p class="font-body text-hub-chumbo/40 text-xs mb-5">Selecione os atributos que descrevem seu negócio</p>
  <div class="flex flex-col gap-5">
    {TAXONOMIES.map(({ group, items }) => (
      <div>
        <p class="font-head font-semibold uppercase tracking-widest text-[11px] text-hub-chumbo/30 mb-2.5">{group}</p>
        <div class="flex flex-wrap gap-2">
          {items.map((item) => (
            <label class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-hub-gelo bg-hub-gelo/50 cursor-pointer hover:border-hub-cobre/40 transition-colors has-[:checked]:bg-hub-cobre/10 has-[:checked]:border-hub-cobre">
              <input type="checkbox" name="tags" value={item} checked={currentTags.includes(item)} class="sr-only" />
              <span class="font-body text-sm text-hub-chumbo/70 select-none">{item}</span>
            </label>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<!-- ── Contato ───────────────────────────────────────────────────────── -->
<div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
  <h3 class="text-hub-pavao text-base mb-5">Contato</h3>
  <div class="flex flex-col gap-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="phone" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Telefone</label>
        <input id="phone" name="phone" type="tel" inputmode="numeric" maxlength="16" value={biz?.phone ?? ''} placeholder="(21) 9999-9999" data-mask="phone" class={inp} />
      </div>
      <div>
        <label for="whatsapp" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">WhatsApp</label>
        <input id="whatsapp" name="whatsapp" type="tel" inputmode="numeric" maxlength="16" value={biz?.whatsapp ?? ''} placeholder="(21) 9 9999-9999" data-mask="phone" class={inp} />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="email" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">E-mail de contato</label>
        <input id="email" name="email" type="email" value={biz?.email ?? ''} placeholder="contato@negocio.com" class={inp} />
      </div>
      <div>
        <label for="website" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Website</label>
        <input id="website" name="website" type="text" value={biz?.website ?? ''} placeholder="seusite.com.br" class={inp} />
      </div>
    </div>
    <div>
      <label for="address" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">Endereço completo</label>
      <input id="address" name="address" type="text" value={biz?.address ?? ''} placeholder="Av. das Américas, 4666 — Barra da Tijuca, RJ" class={inp} />
    </div>
  </div>
</div>
