---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** HTML gerado pelo RankMath SEO via WPGraphQL (fullHead). Quando presente,
   *  substitui o <title> e <meta name="description"> manuais e injeta
   *  todos os meta tags de SEO, OG, Twitter Cards, canonical e JSON-LD. */
  seoHead?: string;
}

const { title, description = "HUBMETROPOLITANO - Diretório Inteligente para a Barra da Tijuca", seoHead } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {seoHead
      ? <Fragment set:html={seoHead} />
      : <>
          <title>{title}</title>
          <meta name="description" content={description} />
        </>
    }

    <!-- Google Fonts: Cormorant Garamond, Barlow, Barlow Condensed -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-hub-gelo text-hub-chumbo min-h-screen flex flex-col antialiased">
    <slot />
  </body>
</html>
