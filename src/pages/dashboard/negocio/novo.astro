---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

// Middleware garante autenticação
const user = Astro.locals.user!;
const supabase = Astro.locals.supabase;

// Busca categorias e localizações para os selects
let categories: { id: number; name: string }[] = [];
let locations:  { id: number; name: string }[] = [];

try {
  const [cats, locs] = await Promise.all([
    supabase.from('categories').select('id, name').order('name'),
    supabase.from('locations').select('id, name').order('name'),
  ]);
  categories = cats.data ?? [];
  locations  = locs.data ?? [];
} catch { /* Supabase ainda não configurado */ }

// ── Utilitário: gera slug ─────────────────────────────────────────────────
function toSlug(text: string): string {
  return text
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

// ── Processamento do POST ─────────────────────────────────────────────────
let error = '';
let fieldErrors: Record<string, string> = {};

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const title       = form.get('title')?.toString().trim()       ?? '';
  const slogan      = form.get('slogan')?.toString().trim()      ?? '';
  const description = form.get('description')?.toString().trim() ?? '';
  const categoryId  = form.get('category_id')?.toString()        ?? '';
  const locationId  = form.get('location_id')?.toString()        ?? '';
  const phone       = form.get('phone')?.toString().trim()       ?? '';
  const whatsapp    = form.get('whatsapp')?.toString().trim()    ?? '';
  const email       = form.get('email')?.toString().trim()       ?? '';
  const websiteRaw  = form.get('website')?.toString().trim()     ?? '';
  const website     = websiteRaw && !/^https?:\/\//i.test(websiteRaw) ? `https://${websiteRaw}` : websiteRaw;
  const address     = form.get('address')?.toString().trim()     ?? '';

  // Validação
  if (!title) fieldErrors.title = 'O nome do negócio é obrigatório.';

  if (Object.keys(fieldErrors).length === 0) {
    // Gera slug base + sufixo aleatório para garantir unicidade
    const slugBase   = toSlug(title);
    const slugSuffix = Math.random().toString(36).slice(2, 6);
    const slug       = `${slugBase}-${slugSuffix}`;

    try {
      const { error: insertError } = await supabase
        .from('businesses')
        .insert({
          owner_id:    user.id,
          title,
          slug,
          slogan:      slogan      || null,
          description: description || null,
          category_id: categoryId  ? parseInt(categoryId)  : null,
          location_id: locationId  ? parseInt(locationId)  : null,
          phone:       phone       || null,
          whatsapp:    whatsapp    || null,
          email:       email       || null,
          website:     website     || null,
          address:     address     || null,
          plan_type:   'free',
          is_active:   true,
        });

      if (insertError) {
        error = 'Erro ao salvar o negócio. Tente novamente.';
        console.error(insertError);
      } else {
        return Astro.redirect('/dashboard?cadastrado=1');
      }
    } catch {
      error = 'Serviço indisponível. Tente novamente em instantes.';
    }
  }
}
---

<Layout
  title="Cadastrar Negócio — Dashboard"
  description="Cadastre seu negócio no HubMetropolitano e apareça no maior diretório da Barra da Tijuca."
>
  <Header />

  <main class="bg-hub-gelo min-h-screen">

    <!-- Topo -->
    <div class="bg-hub-pavao-profundo border-b border-hub-pavao py-8">
      <div class="container mx-auto px-4 lg:px-8 flex items-center gap-3">
        <a href="/dashboard" class="text-hub-gelo/50 hover:text-hub-gelo transition-colors p-1.5 rounded-lg hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
        </a>
        <div>
          <h5 class="text-hub-cobre mb-0.5">Dashboard</h5>
          <h2 class="text-hub-gelo text-xl normal-case font-head font-bold tracking-normal">Cadastrar Negócio</h2>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 py-10 max-w-3xl">

      {error && (
        <div class="mb-6 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-red-500 shrink-0 mt-0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <p class="font-body text-red-600 text-sm">{error}</p>
        </div>
      )}

      <form method="POST" class="flex flex-col gap-6">

        <!-- ── Identificação ─────────────────────────────────────── -->
        <div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
          <h3 class="text-hub-pavao text-base mb-5">Identificação</h3>

          <div class="flex flex-col gap-5">

            <!-- Nome -->
            <div>
              <label for="title" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                Nome do negócio <span class="text-hub-cobre">*</span>
              </label>
              <input
                id="title"
                name="title"
                type="text"
                required
                placeholder="Ex: Restaurante Mar Azul"
                class={`w-full border rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 ${fieldErrors.title ? 'border-red-400' : 'border-hub-gelo'}`}
              />
              {fieldErrors.title && (
                <p class="font-body text-red-500 text-xs mt-1">{fieldErrors.title}</p>
              )}
            </div>

            <!-- Slogan -->
            <div>
              <label for="slogan" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                Slogan <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span>
              </label>
              <input
                id="slogan"
                name="slogan"
                type="text"
                placeholder="Ex: Sabor do mar direto pra você"
                class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
              />
            </div>

            <!-- Categoria + Localização -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="category_id" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  Categoria
                </label>
                <select
                  id="category_id"
                  name="category_id"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 appearance-none"
                >
                  <option value="">Selecione...</option>
                  {categories.map((c) => (
                    <option value={c.id}>{c.name}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="location_id" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  Localização
                </label>
                <select
                  id="location_id"
                  name="location_id"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 appearance-none"
                >
                  <option value="">Selecione...</option>
                  {locations.map((l) => (
                    <option value={l.id}>{l.name}</option>
                  ))}
                </select>
              </div>
            </div>

          </div>
        </div>

        <!-- ── Descrição ──────────────────────────────────────────── -->
        <div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
          <h3 class="text-hub-pavao text-base mb-5">Descrição</h3>

          <div>
            <label for="description" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
              Sobre o negócio <span class="font-body normal-case font-normal tracking-normal text-hub-chumbo/30">(opcional)</span>
            </label>
            <textarea
              id="description"
              name="description"
              rows="5"
              placeholder="Descreva seu negócio, diferenciais, especialidades..."
              class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 resize-none"
            ></textarea>
          </div>
        </div>

        <!-- ── Contato ─────────────────────────────────────────────── -->
        <div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
          <h3 class="text-hub-pavao text-base mb-5">Contato</h3>

          <div class="flex flex-col gap-5">

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <!-- Telefone -->
              <div>
                <label for="phone" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  Telefone
                </label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  inputmode="numeric"
                  maxlength="16"
                  placeholder="(21) 9999-9999"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
                  data-mask="phone"
                />
              </div>

              <!-- WhatsApp -->
              <div>
                <label for="whatsapp" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  WhatsApp
                </label>
                <input
                  id="whatsapp"
                  name="whatsapp"
                  type="tel"
                  inputmode="numeric"
                  maxlength="16"
                  placeholder="(21) 9 9999-9999"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
                  data-mask="phone"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <!-- E-mail -->
              <div>
                <label for="email" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  E-mail de contato
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="contato@negocio.com"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
                />
              </div>

              <!-- Website -->
              <div>
                <label for="website" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                  Website
                </label>
                <input
                  id="website"
                  name="website"
                  type="text"
                  placeholder="seusite.com.br"
                  class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
                />
              </div>
            </div>

            <!-- Endereço -->
            <div>
              <label for="address" class="font-head font-semibold uppercase tracking-wide text-xs text-hub-chumbo/50 mb-1.5 block">
                Endereço completo
              </label>
              <input
                id="address"
                name="address"
                type="text"
                placeholder="Av. das Américas, 4666 — Barra da Tijuca, RJ"
                class="w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40"
              />
            </div>

          </div>
        </div>

        <!-- ── Plano (informativo) ─────────────────────────────────── -->
        <div class="bg-hub-pavao-profundo rounded-2xl p-6 lg:p-8 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-hub-cobre/20 flex items-center justify-center shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-hub-cobre">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
          </div>
          <div>
            <p class="font-head font-semibold uppercase tracking-wider text-xs text-hub-cobre mb-1">Plano Gratuito</p>
            <p class="font-body text-hub-gelo/70 text-sm">Seu negócio será cadastrado gratuitamente. Você poderá fazer upgrade para o plano Premium para adicionar fotos, destaque nos resultados e muito mais.</p>
          </div>
        </div>

        <!-- ── Ações ───────────────────────────────────────────────── -->
        <div class="flex items-center gap-3 justify-end">
          <a
            href="/dashboard"
            class="inline-flex items-center gap-2 border border-hub-chumbo/20 text-hub-chumbo/50 font-head font-semibold uppercase tracking-wide text-sm px-5 py-3 rounded-xl hover:bg-hub-chumbo/5 transition-colors"
          >
            Cancelar
          </a>
          <button
            type="submit"
            class="inline-flex items-center gap-2 bg-hub-cobre text-white font-head font-semibold uppercase tracking-wider text-sm px-6 py-3 rounded-xl hover:bg-hub-cobre-luminoso transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Salvar negócio
          </button>
        </div>

      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Máscara de telefone: (XX) XXXX-XXXX ou (XX) 9 XXXX-XXXX
  function applyPhoneMask(input: HTMLInputElement) {
    input.addEventListener('input', () => {
      let v = input.value.replace(/\D/g, '').slice(0, 11);
      if (v.length === 0) { input.value = ''; return; }
      if (v.length <= 2)  { input.value = `(${v}`; return; }
      if (v.length <= 6)  { input.value = `(${v.slice(0,2)}) ${v.slice(2)}`; return; }
      if (v.length <= 10) { input.value = `(${v.slice(0,2)}) ${v.slice(2,6)}-${v.slice(6)}`; return; }
      // 11 dígitos: celular com 9
      input.value = `(${v.slice(0,2)}) ${v.slice(2,3)} ${v.slice(3,7)}-${v.slice(7)}`;
    });
  }

  document.querySelectorAll<HTMLInputElement>('[data-mask="phone"]').forEach(applyPhoneMask);
</script>
