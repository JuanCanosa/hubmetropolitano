---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BusinessFormFields from '../../../components/BusinessFormFields.astro';

const user     = Astro.locals.user!;
const supabase = Astro.locals.supabase;

// Busca categorias e localizações
let categories: { id: number; name: string }[] = [];
let locations:  { id: number; name: string }[] = [];
try {
  const [cats, locs] = await Promise.all([
    supabase.from('categories').select('id, name').order('name'),
    supabase.from('locations').select('id, name').order('name'),
  ]);
  categories = cats.data ?? [];
  locations  = locs.data ?? [];
} catch {}

function toSlug(text: string): string {
  return text
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

let error = '';
let fieldErrors: Record<string, string> = {};

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const title       = form.get('title')?.toString().trim()       ?? '';
  const slogan      = form.get('slogan')?.toString().trim()      ?? '';
  const description = form.get('description')?.toString().trim() ?? '';
  const categoryId  = form.get('category_id')?.toString()        ?? '';
  const locationId  = form.get('location_id')?.toString()        ?? '';
  const phone       = form.get('phone')?.toString().trim()       ?? '';
  const whatsapp    = form.get('whatsapp')?.toString().trim()    ?? '';
  const email       = form.get('email')?.toString().trim()       ?? '';
  const websiteRaw  = form.get('website')?.toString().trim()     ?? '';
  const website     = websiteRaw && !/^https?:\/\//i.test(websiteRaw) ? `https://${websiteRaw}` : websiteRaw;
  const address     = form.get('address')?.toString().trim()     ?? '';
  const cover_url   = form.get('cover_url')?.toString().trim()   ?? '';
  const logo_url    = form.get('logo_url')?.toString().trim()    ?? '';

  // Taxonomias
  const tags = form.getAll('tags').map(t => t.toString());

  // Identificação extra
  const tipo_servico = form.get('tipo_servico')?.toString().trim() ?? '';
  const faixa_preco  = form.get('faixa_preco')?.toString().trim()  ?? '';

  // Serviços (até 6)
  const servicos: { titulo: string; descricao: string; preco: string }[] = [];
  for (let i = 1; i <= 6; i++) {
    const titulo    = form.get(`servico_titulo_${i}`)?.toString().trim()    ?? '';
    const descricao = form.get(`servico_descricao_${i}`)?.toString().trim() ?? '';
    const preco     = form.get(`servico_preco_${i}`)?.toString().trim()     ?? '';
    if (titulo) servicos.push({ titulo, descricao, preco });
  }

  // Horários
  const h_seg_sex = form.get('horario_seg_sex')?.toString().trim() ?? '';
  const h_sabado  = form.get('horario_sabado')?.toString().trim()  ?? '';
  const h_domingo = form.get('horario_domingo')?.toString().trim() ?? '';
  const horarios: Record<string, string> = {};
  if (h_seg_sex) horarios.seg_sex = h_seg_sex;
  if (h_sabado)  horarios.sabado  = h_sabado;
  if (h_domingo) horarios.domingo = h_domingo;

  // Equipe (até 4)
  const equipe: { nome: string; especialidade: string }[] = [];
  for (let i = 1; i <= 4; i++) {
    const nome          = form.get(`equipe_nome_${i}`)?.toString().trim()          ?? '';
    const especialidade = form.get(`equipe_especialidade_${i}`)?.toString().trim() ?? '';
    if (nome) equipe.push({ nome, especialidade });
  }

  // Lista personalizada
  const lista_label = form.get('lista_extra_label')?.toString().trim() ?? '';
  const lista_raw   = form.get('lista_extra_itens')?.toString().trim() ?? '';
  const lista_extra = lista_label
    ? { label: lista_label, itens: lista_raw.split(',').map(s => s.trim()).filter(Boolean) }
    : null;

  // Informações adicionais
  const areas_atendimento = form.get('areas_atendimento')?.toString().trim() ?? '';
  const tempo_resposta    = form.get('tempo_resposta')?.toString().trim()    ?? '';
  const garantia          = form.get('garantia')?.toString().trim()          ?? '';
  const registro_id       = form.get('registro_id')?.toString().trim()       ?? '';
  const clientes          = form.get('clientes')?.toString().trim()          ?? '';

  // Monta features_json
  const features_json: Record<string, any> = {};
  if (tags.length)                    features_json.tags              = tags;
  if (tipo_servico)                   features_json.tipo_servico      = tipo_servico;
  if (faixa_preco)                    features_json.faixa_preco       = faixa_preco;
  if (servicos.length)                features_json.servicos          = servicos;
  if (Object.keys(horarios).length)   features_json.horarios          = horarios;
  if (equipe.length)                  features_json.equipe            = equipe;
  if (lista_extra)                    features_json.lista_extra       = lista_extra;
  if (areas_atendimento)              features_json.areas_atendimento = areas_atendimento;
  if (tempo_resposta)                 features_json.tempo_resposta    = tempo_resposta;
  if (garantia)                       features_json.garantia          = garantia;
  if (registro_id)                    features_json.registro_id       = registro_id;
  if (clientes)                       features_json.clientes          = clientes;

  // Validação
  if (!title) fieldErrors.title = 'O nome do negócio é obrigatório.';

  if (Object.keys(fieldErrors).length === 0) {
    const slug = `${toSlug(title)}-${Math.random().toString(36).slice(2, 6)}`;

    try {
      const { error: insertError } = await supabase
        .from('businesses')
        .insert({
          owner_id:    user.id,
          title,
          slug,
          slogan:      slogan      || null,
          description: description || null,
          category_id: categoryId  ? parseInt(categoryId)  : null,
          location_id: locationId  ? parseInt(locationId)  : null,
          phone:       phone       || null,
          whatsapp:    whatsapp    || null,
          email:       email       || null,
          website:     website     || null,
          address:     address     || null,
          cover_url:   cover_url   || null,
          logo_url:    logo_url    || null,
          features_json,
          plan_type:   'free',
          is_active:   true,
        });

      if (insertError) {
        error = 'Erro ao salvar o negócio. Tente novamente.';
        console.error(insertError);
      } else {
        return Astro.redirect('/dashboard?cadastrado=1');
      }
    } catch {
      error = 'Serviço indisponível. Tente novamente em instantes.';
    }
  }
}

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL  ?? process.env.PUBLIC_SUPABASE_URL  ?? '';
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? process.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<Layout
  title="Cadastrar Negócio — Dashboard"
  description="Cadastre seu negócio no HubMetropolitano e apareça no maior diretório da Barra da Tijuca."
>
  <Header />

  <main class="bg-hub-gelo min-h-screen">

    <div class="bg-hub-pavao-profundo border-b border-hub-pavao py-8">
      <div class="container mx-auto px-4 lg:px-8 flex items-center gap-3">
        <a href="/dashboard" class="text-hub-gelo/50 hover:text-hub-gelo transition-colors p-1.5 rounded-lg hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
        </a>
        <div>
          <h5 class="text-hub-cobre mb-0.5">Dashboard</h5>
          <h2 class="text-hub-gelo text-xl normal-case font-head font-bold tracking-normal">Cadastrar Negócio</h2>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 py-10 max-w-3xl">

      {error && (
        <div class="mb-6 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-red-500 shrink-0 mt-0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <p class="font-body text-red-600 text-sm">{error}</p>
        </div>
      )}

      <form method="POST" id="business-form" class="flex flex-col gap-6">

        <!-- Hidden inputs para URLs das imagens (preenchidos via JS) -->
        <input type="hidden" name="cover_url" id="cover_url_input" />
        <input type="hidden" name="logo_url"  id="logo_url_input"  />

        <BusinessFormFields categories={categories} locations={locations} fieldErrors={fieldErrors} />

        <!-- Plano (informativo) -->
        <div class="bg-hub-pavao-profundo rounded-2xl p-6 lg:p-8 flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-hub-cobre/20 flex items-center justify-center shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-hub-cobre">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
          </div>
          <div>
            <p class="font-head font-semibold uppercase tracking-wider text-xs text-hub-cobre mb-1">Plano Gratuito</p>
            <p class="font-body text-hub-gelo/70 text-sm">Seu negócio será cadastrado gratuitamente. Faça upgrade para Premium para galeria de fotos, destaque nos resultados e muito mais.</p>
          </div>
        </div>

        <!-- Ações -->
        <div class="flex items-center gap-3 justify-end pb-6">
          <a href="/dashboard" class="inline-flex items-center gap-2 border border-hub-chumbo/20 text-hub-chumbo/50 font-head font-semibold uppercase tracking-wide text-sm px-5 py-3 rounded-xl hover:bg-hub-chumbo/5 transition-colors">
            Cancelar
          </a>
          <button type="submit" id="submit-btn" class="inline-flex items-center gap-2 bg-hub-cobre text-white font-head font-semibold uppercase tracking-wider text-sm px-6 py-3 rounded-xl hover:bg-hub-cobre-luminoso transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
            <svg id="submit-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <svg id="submit-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-4 h-4 animate-spin hidden">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span id="submit-label">Salvar negócio</span>
          </button>
        </div>

      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ supabaseUrl, supabaseAnon, userId: user.id }}>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(supabaseUrl, supabaseAnon);

  const INP_CLASS = 'w-full border border-hub-gelo rounded-xl px-4 py-3 font-body text-hub-chumbo placeholder-hub-chumbo/30 focus:ring-2 focus:ring-hub-cobre/30 focus:border-hub-cobre outline-none transition bg-hub-gelo/40 text-sm';
  const REMOVE_BTN = `<button type="button" class="remove-btn shrink-0 w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 flex items-center justify-center transition-colors"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg></button>`;

  // ── Máscara de telefone ───────────────────────────────────────────────────
  function applyPhoneMask(input) {
    input.addEventListener('input', () => {
      let v = input.value.replace(/\D/g, '').slice(0, 11);
      if (!v) { input.value = ''; return; }
      if (v.length <= 2)  { input.value = `(${v}`; return; }
      if (v.length <= 6)  { input.value = `(${v.slice(0,2)}) ${v.slice(2)}`; return; }
      if (v.length <= 10) { input.value = `(${v.slice(0,2)}) ${v.slice(2,6)}-${v.slice(6)}`; return; }
      input.value = `(${v.slice(0,2)}) ${v.slice(2,3)} ${v.slice(3,7)}-${v.slice(7)}`;
    });
  }
  document.querySelectorAll('[data-mask="phone"]').forEach(applyPhoneMask);

  // ── Upload de imagem ──────────────────────────────────────────────────────
  function setupImageUpload({ fileInputId, previewId, placeholderId, removeId, errorId, hiddenInputId, folder }) {
    const fileInput   = document.getElementById(fileInputId);
    const preview     = document.getElementById(previewId);
    const placeholder = document.getElementById(placeholderId);
    const removeBtn   = document.getElementById(removeId);
    const errorEl     = document.getElementById(errorId);
    const hiddenInput = document.getElementById(hiddenInputId);

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) {
        errorEl.textContent = 'Arquivo muito grande. Máximo 5 MB.';
        errorEl.classList.remove('hidden');
        return;
      }
      errorEl.classList.add('hidden');
      preview.src = URL.createObjectURL(file);
      preview.classList.remove('hidden');
      placeholder.classList.add('hidden');
      removeBtn.classList.remove('hidden');
      removeBtn.classList.add('flex');

      const ext  = file.name.split('.').pop();
      const path = `${userId}/${folder}-${Date.now()}.${ext}`;
      const { data, error } = await supabase.storage.from('businesses').upload(path, file, { upsert: true });
      if (error) {
        errorEl.textContent = 'Erro ao fazer upload. Tente novamente.';
        errorEl.classList.remove('hidden');
        return;
      }
      hiddenInput.value = supabase.storage.from('businesses').getPublicUrl(data.path).data.publicUrl;
    });

    removeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      preview.src = '';
      preview.classList.add('hidden');
      placeholder.classList.remove('hidden');
      removeBtn.classList.add('hidden');
      removeBtn.classList.remove('flex');
      hiddenInput.value = '';
      fileInput.value = '';
    });
  }

  setupImageUpload({ fileInputId:'cover-file', previewId:'cover-preview', placeholderId:'cover-placeholder', removeId:'cover-remove', errorId:'cover-error', hiddenInputId:'cover_url_input', folder:'cover' });
  setupImageUpload({ fileInputId:'logo-file',  previewId:'logo-preview',  placeholderId:'logo-placeholder',  removeId:'logo-remove',  errorId:'logo-error',  hiddenInputId:'logo_url_input',  folder:'logo'  });

  // ── Serviços — adicionar/remover ──────────────────────────────────────────
  const servicosList = document.getElementById('servicos-list');
  const addServico   = document.getElementById('add-servico');
  const MAX_SERVICOS = 6;

  function renumberServicos() {
    const items = servicosList.querySelectorAll('.servico-item');
    items.forEach((item, i) => {
      const n = i + 1;
      const t = item.querySelector('[name^="servico_titulo_"]');
      const d = item.querySelector('[name^="servico_descricao_"]');
      const p = item.querySelector('[name^="servico_preco_"]');
      if (t) { t.name = `servico_titulo_${n}`;    t.placeholder = `Título do serviço ${n}`; }
      if (d) { d.name = `servico_descricao_${n}`; }
      if (p) { p.name = `servico_preco_${n}`;     }
      const rb = item.querySelector('.remove-servico');
      if (rb) rb.style.display = i === 0 ? 'none' : 'flex';
    });
    const count = items.length;
    addServico.style.display = count >= MAX_SERVICOS ? 'none' : '';
  }

  // Esconde o botão remover do primeiro item existente
  renumberServicos();

  servicosList.addEventListener('click', (e) => {
    if (e.target.closest('.remove-servico')) {
      e.target.closest('.servico-item').remove();
      renumberServicos();
    }
  });

  addServico.addEventListener('click', () => {
    const count = servicosList.querySelectorAll('.servico-item').length;
    if (count >= MAX_SERVICOS) return;
    const n = count + 1;
    const div = document.createElement('div');
    div.className = 'servico-item grid grid-cols-1 sm:grid-cols-[1fr_1fr_auto] gap-3 items-start bg-hub-gelo/40 rounded-xl p-4 border border-hub-gelo';
    div.innerHTML = `
      <div class="sm:col-span-2">
        <input name="servico_titulo_${n}" type="text" placeholder="Título do serviço ${n}" class="${INP_CLASS}" />
      </div>
      <div class="flex items-center gap-2 sm:row-start-1 sm:col-start-3">
        <input name="servico_preco_${n}" type="text" placeholder="R$00" class="${INP_CLASS} sm:w-28" />
        <button type="button" class="remove-servico shrink-0 w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="sm:col-span-3">
        <input name="servico_descricao_${n}" type="text" placeholder="Descrição breve (opcional)" class="${INP_CLASS}" />
      </div>`;
    servicosList.appendChild(div);
    renumberServicos();
  });

  // ── Equipe — adicionar/remover ────────────────────────────────────────────
  const equipeList = document.getElementById('equipe-list');
  const addEquipe  = document.getElementById('add-equipe');
  const MAX_EQUIPE = 4;

  function renumberEquipe() {
    const items = equipeList.querySelectorAll('.equipe-item');
    items.forEach((item, i) => {
      const n = i + 1;
      const nm = item.querySelector('[name^="equipe_nome_"]');
      const es = item.querySelector('[name^="equipe_especialidade_"]');
      if (nm) nm.name = `equipe_nome_${n}`;
      if (es) es.name = `equipe_especialidade_${n}`;
      const rb = item.querySelector('.remove-equipe');
      if (rb) rb.style.display = i === 0 ? 'none' : 'flex';
    });
    const count = items.length;
    addEquipe.style.display = count >= MAX_EQUIPE ? 'none' : '';
  }

  renumberEquipe();

  equipeList.addEventListener('click', (e) => {
    if (e.target.closest('.remove-equipe')) {
      e.target.closest('.equipe-item').remove();
      renumberEquipe();
    }
  });

  addEquipe.addEventListener('click', () => {
    const count = equipeList.querySelectorAll('.equipe-item').length;
    if (count >= MAX_EQUIPE) return;
    const n = count + 1;
    const div = document.createElement('div');
    div.className = 'equipe-item grid grid-cols-1 sm:grid-cols-[1fr_1fr_auto] gap-3 items-center';
    div.innerHTML = `
      <input name="equipe_nome_${n}" type="text" placeholder="Nome do profissional" class="${INP_CLASS}" />
      <input name="equipe_especialidade_${n}" type="text" placeholder="Cargo / Especialidade" class="${INP_CLASS}" />
      <button type="button" class="remove-equipe w-8 h-8 rounded-lg bg-red-50 text-red-400 hover:bg-red-100 flex items-center justify-center transition-colors shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>`;
    equipeList.appendChild(div);
    renumberEquipe();
  });

  // ── Feedback no submit ────────────────────────────────────────────────────
  document.getElementById('business-form').addEventListener('submit', () => {
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    document.getElementById('submit-icon').classList.add('hidden');
    document.getElementById('submit-spinner').classList.remove('hidden');
    document.getElementById('submit-label').textContent = 'Salvando...';
  });
</script>
