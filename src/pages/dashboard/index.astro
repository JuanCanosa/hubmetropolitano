---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Middleware garante que só usuários autenticados chegam aqui
const user = Astro.locals.user!;
const supabase = Astro.locals.supabase;

// Busca contagens (retorna 0 se Supabase não configurado ainda)
let businessCount = 0;
let favoriteCount = 0;
let reviewCount   = 0;

try {
  const [biz, fav, rev] = await Promise.all([
    supabase.from('businesses').select('id', { count: 'exact', head: true }).eq('owner_id', user.id),
    supabase.from('favorites').select('business_id', { count: 'exact', head: true }).eq('user_id', user.id),
    supabase.from('reviews').select('id', { count: 'exact', head: true }).eq('user_id', user.id),
  ]);
  businessCount = biz.count ?? 0;
  favoriteCount = fav.count ?? 0;
  reviewCount   = rev.count ?? 0;
} catch {
  // Supabase ainda não configurado — values ficam 0
}

// Busca negócios do usuário
let businesses: any[] = [];
try {
  const { data } = await supabase
    .from('businesses')
    .select('id, title, slug, cover_url, plan_type, is_active, created_at')
    .eq('owner_id', user.id)
    .order('created_at', { ascending: false })
    .limit(10);
  businesses = data ?? [];
} catch { /* silencioso */ }

// Dados do perfil
const displayName = (user.user_metadata?.full_name as string) || user.email?.split('@')[0] || 'Usuário';
const initials    = displayName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();

const cadastrado = Astro.url.searchParams.get('cadastrado') === '1';
const atualizado = Astro.url.searchParams.get('atualizado') === '1';
---

<Layout
  title="Dashboard — HUBMETROPOLITANO"
  description="Gerencie seus negócios e perfil no HubMetropolitano."
>
  <Header />

  <main class="bg-hub-gelo min-h-screen">

    <!-- Header do dashboard -->
    <div class="bg-hub-pavao-profundo border-b border-hub-pavao py-8">
      <div class="container mx-auto px-4 lg:px-8 flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-4">
          <!-- Avatar -->
          <div class="w-12 h-12 rounded-full bg-hub-cobre flex items-center justify-center shrink-0">
            <span class="font-head font-bold text-white text-lg">{initials}</span>
          </div>
          <div>
            <h5 class="text-hub-cobre mb-0.5">Seu painel</h5>
            <h2 class="text-hub-gelo text-xl normal-case font-head font-bold tracking-normal">{displayName}</h2>
          </div>
        </div>

        <!-- Ações -->
        <div class="flex items-center gap-3">
          <a
            href="/dashboard/negocio/novo"
            class="inline-flex items-center gap-2 bg-hub-cobre text-white font-head font-semibold uppercase tracking-wider text-sm px-5 py-2.5 rounded-xl hover:bg-hub-cobre-luminoso transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Cadastrar Negócio
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="inline-flex items-center gap-1.5 border border-hub-gelo/20 text-hub-gelo/70 font-head font-semibold uppercase tracking-wide text-xs px-4 py-2.5 rounded-xl hover:bg-white/10 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
              </svg>
              Sair
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 py-10">

      {atualizado && (
        <div class="mb-6 bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-500 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <p class="font-body text-blue-700 text-sm">Negócio atualizado com sucesso!</p>
        </div>
      )}

      {cadastrado && (
        <div class="mb-6 bg-green-50 border border-green-200 rounded-xl px-4 py-3 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-500 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <p class="font-body text-green-700 text-sm">Negócio cadastrado com sucesso! Ele aparecerá no diretório em breve.</p>
        </div>
      )}

      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
        <div class="bg-white rounded-2xl shadow-sm p-6 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-hub-pavao-soft flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-hub-pavao">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
            </svg>
          </div>
          <div>
            <p class="font-body text-hub-chumbo/40 text-xs uppercase tracking-widest mb-0.5">Negócios</p>
            <p class="font-head font-bold text-hub-pavao text-3xl">{businessCount}</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-red-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </div>
          <div>
            <p class="font-body text-hub-chumbo/40 text-xs uppercase tracking-widest mb-0.5">Favoritos</p>
            <p class="font-head font-bold text-hub-pavao text-3xl">{favoriteCount}</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-yellow-50 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-yellow-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
          </div>
          <div>
            <p class="font-body text-hub-chumbo/40 text-xs uppercase tracking-widest mb-0.5">Avaliações</p>
            <p class="font-head font-bold text-hub-pavao text-3xl">{reviewCount}</p>
          </div>
        </div>
      </div>

      <!-- Meus Negócios -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-6 py-5 border-b border-hub-gelo">
          <h3 class="text-hub-pavao text-lg">Meus Negócios</h3>
          <a
            href="/dashboard/negocio/novo"
            class="inline-flex items-center gap-1.5 font-head font-semibold uppercase tracking-wide text-xs text-hub-cobre hover:text-hub-cobre-luminoso transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Adicionar
          </a>
        </div>

        {businesses.length > 0 ? (
          <ul class="divide-y divide-hub-gelo">
            {businesses.map((b) => (
              <li class="flex items-center gap-4 px-6 py-4 hover:bg-hub-gelo/40 transition-colors">
                {b.cover_url ? (
                  <img src={b.cover_url} alt={b.title} class="w-12 h-12 rounded-xl object-cover shrink-0" />
                ) : (
                  <div class="w-12 h-12 rounded-xl bg-hub-pavao-soft flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-hub-pavao/40">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
                    </svg>
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="font-head font-bold text-hub-chumbo truncate">{b.title}</p>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-head font-semibold uppercase tracking-wide ${b.plan_type === 'premium' ? 'bg-hub-cobre/10 text-hub-cobre' : 'bg-hub-gelo text-hub-chumbo/40'}`}>
                      {b.plan_type === 'premium' ? '★ Premium' : 'Free'}
                    </span>
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-body ${b.is_active ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-500'}`}>
                      {b.is_active ? 'Ativo' : 'Inativo'}
                    </span>
                  </div>
                </div>
                <div class="flex items-center gap-1 shrink-0">
                  {b.slug && (
                    <a href={`/negocio/${b.slug}`} target="_blank" title="Ver página pública" class="text-hub-chumbo/30 hover:text-hub-pavao transition-colors p-1.5 rounded-lg hover:bg-hub-gelo">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      </svg>
                    </a>
                  )}
                  <a href={`/dashboard/negocio/${b.id}`} title="Editar negócio" class="text-hub-chumbo/30 hover:text-hub-pavao transition-colors p-1.5 rounded-lg hover:bg-hub-gelo">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                    </svg>
                  </a>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <!-- Empty state -->
          <div class="px-6 py-16 text-center">
            <div class="w-16 h-16 rounded-full bg-hub-pavao-soft flex items-center justify-center mx-auto mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-hub-pavao/40">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
              </svg>
            </div>
            <h4 class="text-hub-pavao mb-2">Nenhum negócio cadastrado</h4>
            <p class="font-body text-hub-chumbo/50 text-sm max-w-xs mx-auto mb-6">
              Cadastre seu negócio gratuitamente e apareça no maior diretório da Barra da Tijuca.
            </p>
            <a
              href="/dashboard/negocio/novo"
              class="inline-flex items-center gap-2 bg-hub-cobre text-white font-head font-semibold uppercase tracking-wider text-sm px-6 py-3 rounded-xl hover:bg-hub-cobre-luminoso transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Cadastrar meu negócio
            </a>
          </div>
        )}
      </div>

    </div>
  </main>

  <Footer />
</Layout>
