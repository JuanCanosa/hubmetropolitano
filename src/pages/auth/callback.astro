---
/**
 * Callback de autenticação OAuth / Magic Link
 * O Supabase redireciona para esta URL após confirmar o e-mail ou OAuth login.
 * Configurar em: Supabase → Auth → URL Configuration → Redirect URLs
 *   Adicionar: https://seudominio.com.br/auth/callback
 */
import { createSupabaseServerClient } from '../../lib/supabase';

const code = Astro.url.searchParams.get('code');
const next = Astro.url.searchParams.get('next') ?? '/dashboard';

if (code) {
  const supabase = createSupabaseServerClient(Astro);
  const { error } = await supabase.auth.exchangeCodeForSession(code);

  if (!error) {
    return Astro.redirect(next);
  }
}

// Se não há code ou houve erro, redireciona para login
return Astro.redirect('/login?error=callback_failed');
---
