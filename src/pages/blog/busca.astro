---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Busca — Blog HUBMETROPOLITANO">
  <Header />

  <main>
    <section class="bg-hub-pavao text-hub-gelo py-20">
      <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl">
        <span class="font-head text-hub-cobre uppercase tracking-widest font-bold text-sm mb-3 block">Resultados</span>
        <h1 class="font-display text-5xl font-bold mb-6">Busca no Blog</h1>
        <form id="search-form" class="flex gap-3 max-w-xl">
          <div class="relative flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input id="search-input" type="text" name="q" placeholder="Digite sua busca..." class="w-full pl-10 pr-4 py-3 rounded-lg bg-white/10 border border-white/20 font-body text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-hub-cobre" />
          </div>
          <button type="submit" class="bg-hub-cobre text-white font-body font-bold px-6 py-3 rounded-lg hover:bg-white hover:text-hub-chumbo transition-colors">
            Buscar
          </button>
        </form>
      </div>
    </section>

    <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl py-16 min-h-64">
      <p id="search-status" class="font-body text-hub-chumbo/50 mb-8 hidden"></p>

      <!-- Loading -->
      <div id="loading" class="hidden text-center py-24">
        <div class="w-8 h-8 border-2 border-hub-cobre border-t-transparent rounded-full animate-spin mx-auto"></div>
      </div>

      <!-- Results -->
      <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>

      <!-- No results -->
      <div id="no-results" class="hidden text-center py-32">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-hub-chumbo/20 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p class="font-body text-hub-chumbo/40 text-lg">Nenhum resultado encontrado.</p>
        <a href="/blog" class="mt-4 inline-flex items-center font-body text-sm text-hub-cobre hover:underline">Ver todos os posts</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const GQL_URL = 'https://cms.hubcentrometropolitano.com.br/graphql';

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchForm = document.getElementById('search-form') as HTMLFormElement;
  const resultsGrid = document.getElementById('results-grid') as HTMLDivElement;
  const noResults = document.getElementById('no-results') as HTMLDivElement;
  const loading = document.getElementById('loading') as HTMLDivElement;
  const searchStatus = document.getElementById('search-status') as HTMLParagraphElement;

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  function stripHtml(html: string) {
    return html.replace(/<[^>]*>/g, '').trim();
  }

  function renderCard(post: any) {
    const image = post.featuredImage?.node?.sourceUrl;
    const imageAlt = post.featuredImage?.node?.altText || post.title;
    const category = post.categories?.nodes?.[0];
    const excerpt = stripHtml(post.excerpt).slice(0, 140) + '…';

    return `
      <article class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-[#F8FAFA]/50 flex flex-col transform hover:-translate-y-1">
        <a href="/blog/${post.slug}" class="block relative h-52 overflow-hidden bg-[#E6F0F0]">
          ${image
            ? `<img src="${image}" alt="${imageAlt}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />`
            : `<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-[#004445]/20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg></div>`
          }
          ${category ? `<span class="absolute top-4 left-4 bg-[#004445] text-[#F8FAFA] text-xs font-bold uppercase tracking-wider px-3 py-1 rounded shadow-sm">${category.name}</span>` : ''}
        </a>
        <div class="p-6 flex flex-col flex-grow">
          <time class="text-xs text-[#B87333] uppercase tracking-widest mb-3 block font-bold">${formatDate(post.date)}</time>
          <h3 class="text-xl font-bold text-[#004445] mb-3 group-hover:text-[#B87333] transition-colors line-clamp-2" style="font-family:'Cormorant Garamond',serif">
            <a href="/blog/${post.slug}">${post.title}</a>
          </h3>
          <p class="text-[#1A1A1A]/70 text-sm line-clamp-3 mb-6 flex-grow">${excerpt}</p>
          <a href="/blog/${post.slug}" class="mt-auto inline-flex items-center text-[#B87333] font-semibold text-sm hover:text-[#004445] transition-colors">
            Ler artigo
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </article>`;
  }

  async function doSearch(query: string) {
    loading.classList.remove('hidden');
    resultsGrid.innerHTML = '';
    noResults.classList.add('hidden');
    searchStatus.classList.add('hidden');

    try {
      const escaped = query.replace(/"/g, '\\"');
      const res = await fetch(GQL_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: `{
            posts(first: 12, where: { search: "${escaped}" }) {
              nodes {
                slug date
                title(format: RENDERED)
                excerpt(format: RENDERED)
                featuredImage { node { sourceUrl altText } }
                categories { nodes { name slug } }
              }
            }
          }`,
        }),
      });
      const { data } = await res.json();
      const posts = data?.posts?.nodes ?? [];
      loading.classList.add('hidden');

      if (posts.length === 0) {
        noResults.classList.remove('hidden');
        return;
      }

      searchStatus.textContent = `${posts.length} resultado(s) para "${query}"`;
      searchStatus.classList.remove('hidden');
      resultsGrid.innerHTML = posts.map(renderCard).join('');
    } catch {
      loading.classList.add('hidden');
      noResults.classList.remove('hidden');
    }
  }

  const params = new URLSearchParams(window.location.search);
  const q = params.get('q');
  if (q) {
    searchInput.value = q;
    doSearch(q);
  }

  searchForm.addEventListener('submit', e => {
    e.preventDefault();
    const query = searchInput.value.trim();
    if (!query) return;
    window.history.pushState({}, '', `/blog/busca?q=${encodeURIComponent(query)}`);
    doSearch(query);
  });
</script>
