---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/BlogCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCategory, getCategories, getPosts, getPostsCount } from '../../../lib/wordpress';

const { slug } = Astro.params;
const [category, allCategories] = await Promise.all([
  getCategory(slug!),
  getCategories(),
]);
if (!category) return Astro.redirect('/blog');

const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('pagina') ?? '1'));
const perPage = 9;

const [posts, totalCount] = await Promise.all([
  getPosts({ perPage, page: currentPage, categoryId: category.id }),
  getPostsCount({ categoryId: category.id }),
]);

const totalPages = Math.ceil(totalCount / perPage);
const baseUrl = `/blog/categoria/${slug}`;
---

<Layout title={`${category.name} — Blog HUBMETROPOLITANO`}>
  <Header />

  <main>
    <section class="bg-hub-pavao text-hub-gelo py-20">
      <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl">
        <a href="/blog" class="inline-flex items-center font-body text-hub-gelo/50 text-sm mb-6 hover:text-hub-cobre transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          Blog
        </a>
        <span class="font-head text-hub-cobre uppercase tracking-widest font-bold text-sm mb-3 block">Categoria</span>
        <h1 class="font-display text-5xl font-bold">{category.name}</h1>
        <p class="font-body text-hub-gelo/50 mt-2">{category.count} {category.count === 1 ? 'post' : 'posts'}</p>
      </div>
    </section>

    <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl py-16">
      <div class="flex gap-12">

        <!-- Posts -->
        <div class="flex-1 min-w-0">
          {posts.length > 0 ? (
            <>
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                {posts.map(post => <BlogCard post={post} />)}
              </div>
              <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={baseUrl} />
            </>
          ) : (
            <p class="text-center font-body text-hub-chumbo/40 py-32 text-lg">Nenhum post nesta categoria ainda.</p>
          )}
        </div>

        <!-- Sidebar: todas as categorias -->
        <aside class="w-72 hidden lg:block shrink-0">
          <div class="bg-white rounded-xl p-6 border border-hub-gelo shadow-sm">
            <h3 class="font-head uppercase tracking-widest text-sm font-bold text-hub-chumbo mb-5 pb-3 border-b border-hub-gelo">
              Categorias
            </h3>
            <ul class="space-y-2">
              {allCategories.map(cat => {
                const isActive = cat.slug === slug;
                return (
                  <li>
                    {isActive ? (
                      <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-hub-pavao text-hub-gelo cursor-default">
                        <span class="font-body text-sm font-semibold">{cat.name}</span>
                        <span class="text-hub-gelo/60 text-xs">{cat.count}</span>
                      </div>
                    ) : (
                      <a
                        href={`/blog/categoria/${cat.slug}`}
                        class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-hub-pavao-soft transition-colors group"
                      >
                        <span class="font-body text-sm text-hub-chumbo/80 group-hover:text-hub-pavao group-hover:translate-x-1 transition-all">{cat.name}</span>
                        <span class="bg-hub-gelo text-hub-chumbo/40 text-xs px-2 py-0.5 rounded-full">{cat.count}</span>
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
