---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { mockBusinesses, mockBusinessesB2B, mockBusinessesTec, mockBusinessesGastro } from '../../utils/mockBusinesses';

const allBusinesses = [
  ...mockBusinesses.filter(b => b.type === 'digital'),
  ...mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais'),
  ...mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos'),
  ...mockBusinessesGastro.filter(b => b.type === 'gastronomia'),
];

const typeTabs = [
  { id: 'all',                    label: 'Todos',             count: allBusinesses.length },
  { id: 'digital',                label: 'Agências Digitais', count: mockBusinesses.filter(b => b.type === 'digital').length },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length },
  { id: 'gastronomia',            label: 'Gastronomia',        count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length },
];

const ltCategories = [
  { id: 'digital',                label: 'Agências Digitais', icon: '💻', count: mockBusinesses.filter(b => b.type === 'digital').length,                cover: mockBusinesses[0].cover },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', icon: '🏛️', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length, cover: mockBusinessesB2B[0].cover },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   icon: '🔧', count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length,      cover: mockBusinessesTec[0].cover },
  { id: 'gastronomia',            label: 'Gastronomia',        icon: '🍽️', count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length,         cover: mockBusinessesGastro[0].cover },
];

const subcatGroups = [
  {
    typeId: 'digital',
    cover: mockBusinesses[0].cover,
    subs: [
      { name: 'Marketing Digital', icon: '📣' },
      { name: 'Dev Web & Apps',    icon: '💻' },
      { name: 'Design Visual',     icon: '🎨' },
      { name: 'Tráfego & Growth',  icon: '📈' },
      { name: 'Automação',         icon: '⚙️' },
    ],
  },
  {
    typeId: 'servicos-profissionais',
    cover: mockBusinessesB2B[0].cover,
    subs: [
      { name: 'Contabilidade', icon: '📊' },
      { name: 'Imobiliária',   icon: '🏠' },
      { name: 'Seguros',       icon: '🛡️' },
      { name: 'Consultoria',   icon: '💼' },
      { name: 'RH',            icon: '👥' },
    ],
  },
  {
    typeId: 'servicos-tecnicos',
    cover: mockBusinessesTec[0].cover,
    subs: [
      { name: 'Reforma & Construção', icon: '🔨' },
      { name: 'Eletricidade',         icon: '⚡' },
      { name: 'Ar-Condicionado',      icon: '❄️' },
      { name: 'Pet Care',             icon: '🐾' },
      { name: 'Transporte',           icon: '🚚' },
    ],
  },
  {
    typeId: 'gastronomia',
    cover: mockBusinessesGastro[0].cover,
    subs: [
      { name: 'Restaurantes',     icon: '🍽️' },
      { name: 'Cafeterias',       icon: '☕' },
      { name: 'Delivery',         icon: '🛵' },
      { name: 'Eventos & Buffet', icon: '🎉' },
      { name: 'Bares & Drinks',   icon: '🍹' },
    ],
  },
];

const urgenciaConfig: Record<string, { label: string; color: string }> = {
  'sim-24h':       { label: '⚡ Urgência 24h',    color: 'bg-red-500 text-white' },
  'sim-comercial': { label: '✓ Atende urgências', color: 'bg-amber-500 text-white' },
};

function getBusinessUrl(b: (typeof allBusinesses)[0]) {
  if (b.type === 'servicos-profissionais') return `/servicos-profissionais/${b.slug}`;
  if (b.type === 'servicos-tecnicos')      return `/servicos-tecnicos/${b.slug}`;
  if (b.type === 'gastronomia')            return `/gastronomia/${b.slug}`;
  return `/digital/${b.slug}`;
}

// TODO: WP — este array virá de uma Custom Taxonomy 'empreendimento' do WordPress
// Substituir por: await fetch(`${WP_API}/wp-json/wp/v2/empreendimento`)
const empreendimentos = [
  'Cidade Jardim', 'Rio2', 'Ilha Pura', 'Union Square',
  'Worldwide Offices', 'CEO', 'Metropolitan',
];

// TODO: WP — o campo 'empreendimento' virá do meta field (ACF) no CPT 'listing'
// Substituir por: post.acf.empreendimento || post.meta._empreendimento
// Por enquanto, atribuição estática cíclica para validação de layout
const bizEmpreendimento: Record<string, string> = Object.fromEntries(
  allBusinesses.map((b, i) => [b.slug, empreendimentos[i % empreendimentos.length]])
);
---

<Layout
  title="Serviços — HUBMETROPOLITANO"
  description="Agências digitais, profissionais B2B e técnicos especializados verificados na Barra da Tijuca."
>
  <Header />

  <main>
    <!-- Hero compacto -->
    <div class="bg-hub-pavao-profundo py-10 lg:py-14">
      <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl">
        <h5 class="text-hub-cobre mb-3">Vitrine de Negócios</h5>
        <h1 class="text-white mb-6 max-w-2xl">
          Serviços<br /><span class="text-hub-cobre">Verificados</span>
        </h1>
        <div class="relative max-w-2xl">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-hub-chumbo/40 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Buscar agência, serviço, especialidade..."
            class="w-full bg-white text-hub-chumbo font-body text-base pl-12 pr-4 py-3.5 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-hub-cobre transition-shadow"
          />
        </div>
      </div>
    </div>

    <!-- Top icon bar: listing types -->
    <div class="bg-white border-b border-hub-gelo sticky top-[64px] z-20 shadow-sm">
      <div class="flex items-center gap-3 overflow-x-auto px-6 py-4" style="scrollbar-width: none; -ms-overflow-style: none;">
        {[
          { id: 'all',                    icon: '🏢', label: 'Todos',              count: allBusinesses.length },
          { id: 'digital',                icon: '💻', label: 'Agências Digitais',   count: mockBusinesses.filter(b => b.type === 'digital').length },
          { id: 'servicos-profissionais', icon: '🏛️', label: 'Profissionais B2B',   count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length },
          { id: 'servicos-tecnicos',      icon: '🔧', label: 'Técnicos & Casa',     count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length },
          { id: 'gastronomia',            icon: '🍽️', label: 'Gastronomia',          count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length },
        ].map((t, i) => (
          <button
            data-type-icon={t.id}
            class={`type-icon-btn flex items-center gap-3 px-5 py-2.5 rounded-full border shrink-0 transition-all duration-200 ${
              i === 0
                ? 'bg-hub-pavao border-hub-pavao text-white'
                : 'bg-white border-hub-gelo text-hub-chumbo/60 hover:border-hub-pavao hover:text-hub-pavao'
            }`}
          >
            <span class="text-lg leading-none">{t.icon}</span>
            <span class="font-head font-semibold uppercase tracking-wide text-base whitespace-nowrap">{t.label}</span>
            <span class="font-body text-sm opacity-60">({t.count})</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Layout: sidebar + grid de resultados -->
    <div class="flex items-start pt-[30px]">

      <!-- ── Sidebar de Filtros ─────────────────────────────────────── -->
      <aside id="sidebar" class="hidden lg:flex w-[280px] shrink-0 flex-col bg-white border-r border-hub-gelo">

        <!-- Filtros -->
        <div id="panel-filtros" class="flex-1 overflow-y-auto flex flex-col min-h-0">

          <div class="flex-1 p-4 flex flex-col gap-5">

            <!--
              Localização / Empreendimento
              TODO: WP — os itens desta lista virão de uma Custom Taxonomy 'empreendimento'
              Fetch: GET /wp-json/wp/v2/empreendimento?per_page=100
              Renderizar dinamicamente substituindo a lista estática abaixo
            -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Localização</p>
              <div class="flex flex-col gap-2">
                {empreendimentos.map(emp => (
                  <label class="flex items-center gap-2.5 cursor-pointer group">
                    <input
                      type="checkbox"
                      data-empreendimento-filter={emp}
                      class="empreendimento-cb w-4 h-4 rounded border-hub-gelo text-hub-pavao accent-hub-pavao cursor-pointer shrink-0"
                    />
                    <span class="font-body text-sm text-hub-chumbo/70 group-hover:text-hub-pavao transition-colors">{emp}</span>
                  </label>
                ))}
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- O que você procura? -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">O que você procura?</p>
              <div id="subcat-list" class="flex flex-wrap gap-1.5">
                <p class="font-body text-hub-chumbo/40 text-base py-1">Selecione um tipo acima</p>
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- Avaliação -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Avaliação</p>
              <div class="grid grid-cols-2 gap-1.5">
                <button data-rating="5"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★★★<br/><span class="text-sm text-hub-chumbo/40">5 estrelas</span></button>
                <button data-rating="4"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★★<br/><span class="text-sm text-hub-chumbo/40">4+ estrelas</span></button>
                <button data-rating="3"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★<br/><span class="text-sm text-hub-chumbo/40">3+ estrelas</span></button>
                <button data-rating="2"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★<br/><span class="text-sm text-hub-chumbo/40">2+ estrelas</span></button>
                <button data-rating="0"   class="rating-btn col-span-2 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base bg-hub-pavao text-white border-hub-pavao transition-colors">Qualquer nota</button>
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- Urgência (só LT3) -->
            <div id="urgencia-section" class="hidden">
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Urgência</p>
              <div class="flex flex-col gap-1.5">
                <button data-urgencia=""             class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors bg-hub-pavao text-white border-hub-pavao">Todas</button>
                <button data-urgencia="sim-24h"      class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">⚡ Urgência 24h</button>
                <button data-urgencia="sim-comercial" class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">✓ Horário comercial</button>
              </div>
            </div>

          </div>

          <!-- Botão Buscar (sticky bottom) -->
          <div class="shrink-0 p-4 bg-white border-t border-hub-gelo">
            <button id="apply-filters-btn" class="w-full bg-hub-pavao text-white font-head font-semibold uppercase tracking-wider text-base py-3 rounded-xl hover:bg-hub-pavao-profundo transition-colors flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              Buscar
            </button>
          </div>

        </div>

      </aside>

      <!-- ── Área de Resultados ────────────────────────────────────── -->
      <!-- TODO: WP — substituir allBusinesses pelo resultado da query ao WP REST API -->
      <div id="results-panel" class="flex-1 min-w-0 bg-hub-gelo">

        <!-- Compact bar: count + toggle -->
        <div class="sticky top-0 z-10 bg-hub-gelo/95 backdrop-blur-sm border-b border-hub-gelo/60 px-4 lg:px-5 py-3 flex items-center justify-between gap-3">
          <p id="results-count" class="font-body text-hub-chumbo/50 text-sm whitespace-nowrap">
            {allBusinesses.length} encontrados
          </p>
          <div class="flex items-center gap-0.5 bg-white border border-hub-gelo rounded-lg p-1 shadow-sm shrink-0">
            <button id="view-grid" aria-label="Grid" class="p-1.5 rounded bg-hub-pavao text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
              </svg>
            </button>
            <button id="view-list" aria-label="Lista" class="p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Cards grid — responsivo: 1 col mobile / 2 tablet / 3 desktop -->
        <div id="listings-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 p-4 lg:p-6">
          {/* TODO: WP — substituir allBusinesses por posts vindos do WP REST API */}
          {/* GET /wp-json/wp/v2/listing?per_page=12&_embed&empreendimento=<id> */}
          {allBusinesses.map(b => {
            const url           = getBusinessUrl(b);
            const hasUrgencia   = b.atendeUrgencia === 'sim-24h';
            const stars         = b.rating ? '★'.repeat(Math.round(b.rating)) + '☆'.repeat(5 - Math.round(b.rating)) : null;
            // TODO: WP — virá de b.acf.empreendimento ou taxonomy term
            const empreendimento = bizEmpreendimento[b.slug];
            return (
              <a
                href={url}
                data-slug={b.slug}
                data-type={b.type}
                data-category={b.category.toLowerCase()}
                data-title={b.title.toLowerCase()}
                data-lat={b.lat}
                data-lng={b.lng}
                data-rating={b.rating ?? 0}
                data-urgencia={b.atendeUrgencia ?? ''}
                data-cover={b.cover}
                data-logo={b.logo ?? ''}
                data-tagline={b.tagline}
                data-description={b.description}
                data-location={b.location ?? ''}
                data-faixa={b.faixaHonorarios ?? ''}
                data-cat-label={b.category}
                data-empreendimento={empreendimento}
                class="biz-card group flex flex-col bg-white rounded-2xl border border-hub-gelo shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-visible"
              >
                {/* Cover + logo wrapper */}
                <div class="relative">
                  {/* Image (clipped) */}
                  <div class="card-cover relative h-44 overflow-hidden rounded-t-2xl bg-hub-pavao-profundo shrink-0">
                    <img src={b.cover} alt={b.title} loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />

                    {/* Badge row at top of image */}
                    <div class="absolute top-0 left-0 right-0 flex items-center gap-1 p-2">
                      {hasUrgencia && (
                        <span class="flex items-center justify-center w-7 h-7 rounded bg-amber-500 text-white text-sm shrink-0" title="Urgência 24h">⚡</span>
                      )}
                      {b.faixaHonorarios && (
                        <span class="bg-black/65 backdrop-blur-sm text-white text-[11px] font-body px-2 py-1 rounded">$$</span>
                      )}
                      {stars && (
                        <span class="bg-black/65 backdrop-blur-sm text-amber-400 text-[11px] font-body px-2 py-1 rounded tracking-tight">{stars}</span>
                      )}
                      {b.rating && (
                        <span class="bg-black/65 backdrop-blur-sm text-white text-[11px] font-body font-semibold px-2 py-1 rounded">{b.rating.toFixed(1)}</span>
                      )}
                      <span class="ml-auto bg-white text-hub-chumbo text-[11px] font-body font-semibold px-2.5 py-1 rounded shadow">Ver Perfil</span>
                    </div>
                  </div>

                  {/* Logo overlapping image bottom */}
                  {b.logo ? (
                    <img src={b.logo} alt={b.title}
                      class="absolute bottom-0 translate-y-1/2 left-3 w-14 h-14 rounded-full border-2 border-white object-cover bg-white shadow-md z-10" />
                  ) : (
                    <div class="absolute bottom-0 translate-y-1/2 left-3 w-14 h-14 rounded-full border-2 border-white bg-hub-pavao flex items-center justify-center shadow-md z-10">
                      <span class="text-white font-head font-bold text-xl">{b.title.charAt(0)}</span>
                    </div>
                  )}
                </div>

                {/* Card body */}
                <div class="card-body pt-9 px-4 pb-2">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <h3 class="font-head font-bold text-hub-chumbo group-hover:text-hub-cobre transition-colors text-base uppercase tracking-wide leading-tight">
                      {b.title}
                    </h3>
                    {/* Verified checkmark */}
                    <svg class="w-4 h-4 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.491 4.491 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <p class="font-body text-sm text-hub-chumbo/60 mt-1 leading-snug line-clamp-2">{b.tagline}</p>
                  {/* Badge de empreendimento — TODO: WP: taxonomy term 'empreendimento' */}
                  <span class="inline-block mt-2 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">
                    {empreendimento}
                  </span>
                </div>

                {/* Card footer */}
                <div class="card-footer flex items-center justify-between px-4 py-3 mt-auto">
                  <span class="flex items-center gap-1.5 border border-hub-gelo rounded-full px-2.5 py-1 text-xs font-body text-hub-chumbo/60">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3 h-3 text-red-400 shrink-0">
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    {b.category.split(' ')[0]}
                  </span>
                  <div class="flex items-center gap-2">
                    <button onclick="event.preventDefault();event.stopPropagation();openQuickView(this.closest('.biz-card'))" class="p-2 rounded-full text-hub-chumbo/40 hover:bg-hub-gelo hover:text-hub-pavao transition-colors" aria-label="Quick view">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                      </svg>
                    </button>
                    <button onclick="event.preventDefault();event.stopPropagation()" class="p-2 rounded-full text-hub-chumbo/40 hover:bg-hub-pavao hover:text-white transition-colors" aria-label="Favoritar">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <div id="no-results" class="hidden px-6 py-20 text-center">
          <p class="font-head font-bold text-hub-pavao text-xl uppercase mb-2">Nenhum resultado</p>
          <p class="font-body text-hub-chumbo/50 text-sm">Tente outros termos ou remova os filtros.</p>
        </div>
      </div>

    </div>
  </main>

  <Footer />

  <script is:inline>
  (function () {
    var subcategoriesByType = {
      all:                      [],
      digital:                  ['Marketing Digital', 'Dev Web & Apps', 'Design Visual', 'Tráfego & Growth', 'Automação'],
      'servicos-profissionais': ['Contabilidade', 'Imobiliária', 'Seguros', 'Consultoria', 'RH'],
      'servicos-tecnicos':      ['Reforma & Construção', 'Eletricidade', 'Ar-Condicionado', 'Pet Care', 'Transporte'],
      gastronomia:              ['Restaurantes', 'Cafeterias', 'Delivery', 'Eventos & Buffet', 'Bares & Drinks'],
    };
    var typeColors = {
      digital:                '#B87333',
      'servicos-profissionais': '#004445',
      'servicos-tecnicos':    '#374151',
    };

    var state = { query: '', type: 'all', subcategory: '', minRating: 0, urgencia: '', empreendimentos: [], view: 'grid' };

    var searchInput   = document.getElementById('search-input');
    var listingsCont  = document.getElementById('listings-container');
    var resultsCount  = document.getElementById('results-count');
    var noResults     = document.getElementById('no-results');
    var viewGridBtn   = document.getElementById('view-grid');
    var viewListBtn   = document.getElementById('view-list');
    var cards           = document.querySelectorAll('.biz-card');
    var subcatList      = document.getElementById('subcat-list');
    var urgenciaSection = document.getElementById('urgencia-section');

    /* ── filtros ────────────────────────────────────────────────── */
    function applyFilters() {
      var q          = state.query.toLowerCase();
      var t          = state.type;
      var sub        = state.subcategory.toLowerCase();
      var minRating  = state.minRating;
      var urg        = state.urgencia;
      var empFilter  = state.empreendimentos; // array de strings selecionadas
      var visible    = 0;

      cards.forEach(function (card) {
        var ct   = card.dataset.type          || '';
        var ccat = card.dataset.category      || '';
        var ctit = card.dataset.title         || '';
        var crat = parseFloat(card.dataset.rating    || '0');
        var curg = card.dataset.urgencia      || '';
        var cemp = card.dataset.empreendimento || '';

        var show = (t === 'all' || ct === t) &&
                   (!sub       || ccat.includes(sub)) &&
                   (!q         || ctit.includes(q) || ccat.includes(q)) &&
                   (!minRating || crat >= minRating) &&
                   (!urg       || curg === urg) &&
                   (empFilter.length === 0 || empFilter.indexOf(cemp) !== -1);

        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (resultsCount) resultsCount.textContent = visible + ' encontrados';
      if (noResults && listingsCont) {
        noResults.style.display     = visible === 0 ? '' : 'none';
        listingsCont.style.display  = visible === 0 ? 'none' : '';
      }
    }


    /* ── subcategorias (chips) ──────────────────────────────────── */
    function setSubcat(cat) {
      state.subcategory = cat;
      document.querySelectorAll('.subcat-item').forEach(function (el) {
        var active = el.dataset.cat === cat;
        el.className = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    function renderSubcatList(type) {
      if (!subcatList) return;
      var cats = subcategoriesByType[type] || [];
      subcatList.innerHTML = '';
      if (cats.length === 0) {
        subcatList.innerHTML = '<p class="font-body text-hub-chumbo/40 text-xs py-1 w-full">Selecione uma categoria acima</p>';
        return;
      }
      var allBtn = document.createElement('button');
      allBtn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer bg-hub-pavao text-white border-hub-pavao';
      allBtn.dataset.cat = '';
      allBtn.textContent = 'Todas';
      allBtn.addEventListener('click', function () { setSubcat(''); });
      subcatList.appendChild(allBtn);
      cats.forEach(function (cat) {
        var btn = document.createElement('button');
        btn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao';
        btn.dataset.cat = cat;
        btn.textContent = cat;
        btn.addEventListener('click', function () { setSubcat(cat); });
        subcatList.appendChild(btn);
      });
    }

    /* ── rating ─────────────────────────────────────────────────── */
    function setRating(minRating) {
      state.minRating = minRating;
      document.querySelectorAll('.rating-btn').forEach(function (btn) {
        var val = parseFloat(btn.dataset.rating || '0');
        var active = val === minRating;
        var isQualquer = val === 0;
        btn.className = 'rating-btn text-center px-2 py-2 rounded-lg border font-body text-base transition-colors leading-tight ' +
          (isQualquer ? 'col-span-2 ' : 'col-span-1 ') +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.rating-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setRating(parseFloat(btn.dataset.rating || '0')); });
    });

    /* ── urgência ───────────────────────────────────────────────── */
    function setUrgencia(val) {
      state.urgencia = val;
      document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
        var active = btn.dataset.urgencia === val;
        btn.className = 'urgencia-btn text-left px-3 py-2.5 rounded-lg border font-body text-base transition-colors ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setUrgencia(btn.dataset.urgencia || ''); });
    });

    /* ── botão buscar (só aplica filtros, já reativo por default) ── */
    var applyBtn = document.getElementById('apply-filters-btn');
    if (applyBtn) applyBtn.addEventListener('click', applyFilters);

    function activateType(newType) {
      state.type        = newType;
      state.subcategory = '';
      state.urgencia    = '';

      renderSubcatList(newType);
      if (urgenciaSection) urgenciaSection.style.display = newType === 'servicos-tecnicos' ? '' : 'none';
      setUrgencia('');
      applyFilters();
    }

    /* ── top icon bar ───────────────────────────────────────────── */
    function updateIconBar(newType) {
      document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
        var active = btn.dataset.typeIcon === newType;
        btn.className = 'type-icon-btn flex items-center gap-3 px-5 py-2.5 rounded-full border shrink-0 transition-all duration-200 ' +
          (active ? 'bg-hub-pavao border-hub-pavao text-white' : 'bg-white border-hub-gelo text-hub-chumbo/60 hover:border-hub-pavao hover:text-hub-pavao');
      });
    }

    document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var t = btn.dataset.typeIcon || 'all';
        updateIconBar(t);
        activateType(t);
      });
    });

    /* ── busca ──────────────────────────────────────────────────── */
    var searchTimer;
    if (searchInput) {
      searchInput.addEventListener('input', function (e) {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function () { state.query = e.target.value.trim(); applyFilters(); }, 200);
      });
    }

    /* ── grid / lista ───────────────────────────────────────────── */
    if (viewGridBtn) {
      viewGridBtn.addEventListener('click', function () {
        state.view = 'grid';
        if (listingsCont) listingsCont.classList.remove('is-list-view');
        viewGridBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewListBtn) viewListBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }
    if (viewListBtn) {
      viewListBtn.addEventListener('click', function () {
        state.view = 'list';
        if (listingsCont) listingsCont.classList.add('is-list-view');
        viewListBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewGridBtn) viewGridBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }

    /* ── filtro empreendimento (checkboxes) ─────────────────────── */
    // TODO: WP — quando os dados vierem da API, os checkboxes serão gerados dinamicamente
    document.querySelectorAll('.empreendimento-cb').forEach(function (cb) {
      cb.addEventListener('change', function () {
        var emp = cb.dataset.empreendimentoFilter || '';
        if (cb.checked) {
          if (state.empreendimentos.indexOf(emp) === -1) state.empreendimentos.push(emp);
        } else {
          state.empreendimentos = state.empreendimentos.filter(function (e) { return e !== emp; });
        }
        applyFilters();
      });
    });

    /* ── init ───────────────────────────────────────────────────── */
    updateIconBar('all');
    renderSubcatList('all');
    setRating(0);
    setUrgencia('');
    applyFilters();

    /* ── quickview ──────────────────────────────────────────────── */
    window.openQuickView = function (card) {
      if (!card) return;
      var d = card.dataset;
      document.getElementById('qv-cover').src = d.cover || '';
      document.getElementById('qv-cover').alt = d.title || '';
      document.getElementById('qv-title').textContent = d.title || '';
      document.getElementById('qv-description').textContent = d.description || '';
      document.getElementById('qv-category').textContent = d.catLabel || '';

      var locRow = document.getElementById('qv-location-row');
      var locEl  = document.getElementById('qv-location');
      if (d.location) { locEl.textContent = d.location; locRow.style.display = 'flex'; }
      else { locRow.style.display = 'none'; }

      var logoImg  = document.getElementById('qv-logo');
      var logoInit = document.getElementById('qv-logo-initial');
      if (d.logo) {
        logoImg.src = d.logo; logoImg.style.display = ''; logoInit.style.display = 'none';
      } else {
        logoImg.style.display = 'none';
        logoInit.textContent = (d.title || 'X').charAt(0).toUpperCase();
        logoInit.style.display = '';
      }

      document.getElementById('qv-badge-urgencia').style.display = d.urgencia === 'sim-24h' ? 'flex' : 'none';
      document.getElementById('qv-badge-price').style.display    = d.faixa ? '' : 'none';

      var rating  = parseFloat(d.rating || '0');
      var starsEl = document.getElementById('qv-badge-stars');
      var scoreEl = document.getElementById('qv-badge-score');
      if (rating > 0) {
        starsEl.textContent = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
        starsEl.style.display = ''; scoreEl.textContent = rating.toFixed(1); scoreEl.style.display = '';
      } else {
        starsEl.style.display = 'none'; scoreEl.style.display = 'none';
      }

      document.getElementById('qv-cta').href = card.getAttribute('href') || '#';
      document.getElementById('qv-overlay').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };

    function closeQuickView() {
      document.getElementById('qv-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }

    document.getElementById('qv-close-btn').addEventListener('click', closeQuickView);
    document.getElementById('qv-overlay').addEventListener('click', function (e) {
      if (e.target === this) closeQuickView();
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeQuickView(); });

  })();
  </script>

  <!-- ── QuickView Lightbox ─────────────────────────────────────── -->
  <div id="qv-overlay" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none;background:rgba(0,0,0,0.65)">
    <div id="qv-modal" class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden" style="max-height:90vh;overflow-y:auto">

      <!-- Cover -->
      <div class="relative h-56 shrink-0">
        <img id="qv-cover" src="" alt="" class="w-full h-full object-cover" />
        <div class="absolute top-0 left-0 right-0 flex items-center gap-1 p-3">
          <span id="qv-badge-urgencia" class="items-center justify-center w-7 h-7 rounded bg-amber-500 text-white text-sm" style="display:none">⚡</span>
          <span id="qv-badge-price" class="bg-black/65 text-white text-[11px] font-body px-2 py-1 rounded" style="display:none">$$</span>
          <span id="qv-badge-stars" class="bg-black/65 text-amber-400 text-[11px] font-body px-2 py-1 rounded tracking-tight"></span>
          <span id="qv-badge-score" class="bg-black/65 text-white text-[11px] font-body font-semibold px-2 py-1 rounded" style="display:none"></span>
        </div>
        <button id="qv-close-btn" class="absolute top-3 right-3 bg-white/90 hover:bg-white rounded-full p-1.5 text-hub-chumbo transition-colors shadow">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <!-- Logo overlapping -->
        <div class="absolute -bottom-6 left-5 w-14 h-14 rounded-full border-2 border-white shadow-md bg-hub-pavao flex items-center justify-center overflow-hidden z-10">
          <img id="qv-logo" src="" alt="" class="w-full h-full object-cover" style="display:none" />
          <span id="qv-logo-initial" class="text-white font-head font-bold text-xl" style="display:none"></span>
        </div>
      </div>

      <!-- Header -->
      <div class="pt-9 px-5 pb-4 border-b border-hub-gelo">
        <div class="flex items-center gap-1.5 flex-wrap">
          <h2 id="qv-title" class="font-head font-bold text-hub-chumbo text-lg uppercase tracking-wide leading-tight"></h2>
          <svg class="w-4 h-4 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.491 4.491 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
          </svg>
        </div>
        <div id="qv-location-row" class="items-center gap-1.5 mt-1.5 text-hub-chumbo/60 text-sm font-body" style="display:none">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0 text-hub-cobre">
            <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
          </svg>
          <span id="qv-location"></span>
        </div>
      </div>

      <!-- Body -->
      <div class="px-5 py-5 space-y-5">
        <div>
          <h3 class="flex items-center gap-2 font-head font-bold text-hub-chumbo text-xs uppercase tracking-widest mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-hub-cobre">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            Descrição
          </h3>
          <p id="qv-description" class="font-body text-sm text-hub-chumbo/70 leading-relaxed"></p>
        </div>
        <div>
          <h3 class="flex items-center gap-2 font-head font-bold text-hub-chumbo text-xs uppercase tracking-widest mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-hub-cobre">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
            Categorias
          </h3>
          <div class="flex items-center gap-3">
            <span class="w-9 h-9 rounded-full bg-red-500 flex items-center justify-center text-white shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </span>
            <span id="qv-category" class="font-body text-hub-chumbo text-sm font-medium"></span>
          </div>
        </div>
        <a id="qv-cta" href="#" class="flex items-center justify-center gap-2 w-full bg-hub-pavao text-white font-head font-semibold uppercase tracking-wide text-sm py-3 rounded-xl hover:bg-hub-pavao-profundo transition-colors">
          Ver Perfil Completo
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Sidebar sticky — ocupa altura disponível abaixo do header + icon bar */
  @media (min-width: 1024px) {
    #sidebar {
      position: sticky;
      top: 136px; /* header ~64px + icon bar ~72px */
      height: calc(100vh - 136px);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
  }

  /* View lista: colapsa para coluna única */
  #listings-container.is-list-view { grid-template-columns: 1fr !important; }
  #listings-container.is-list-view .biz-card { flex-direction: row; }
  #listings-container.is-list-view .card-cover { width: 160px; min-width: 160px; height: auto; min-height: 130px; }
  #listings-container.is-list-view .card-footer { display: none; }
</style>
