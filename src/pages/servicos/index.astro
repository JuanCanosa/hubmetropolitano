      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    #left-panel {
      height: calc(100vh - var(--map-offset, 114px));
      overflow-y: auto;
    }
    #map-panel {
      position: sticky;
      top: var(--map-offset, 114px);
      height: calc(100vh - var(--map-offset, 114px));
    }
  }

  #listings-container.is-list-view { grid-template-columns: 1fr !important; }
  #listings-container.is-list-view .biz-card { flex-direction: row; }
  #listings-container.is-list-view .card-cover { width: 160px; min-width: 160px; height: auto; min-height: 130px; }
  #listings-container.is-list-view .card-footer { display: none; }

  .biz-card.map-highlight {
    box-shadow: 0 0 0 3px #B87333, 0 12px 28px rgba(0,0,0,.15) !important;
    transform: translateY(-4px) !important;
