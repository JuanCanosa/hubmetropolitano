---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BusinessCard from '../../components/BusinessCard.astro';
import { mockBusinesses, mockBusinessesB2B, mockBusinessesTec, mockBusinessesGastro, mockBusinessesSaude, mockBusinessesEsporte, mockBusinessesBeleza } from '../../utils/mockBusinesses';

const allBusinesses = [
  ...mockBusinesses.filter(b => b.type === 'digital'),
  ...mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais'),
  ...mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos'),
  ...mockBusinessesGastro.filter(b => b.type === 'gastronomia'),
  ...mockBusinessesSaude.filter(b => b.type === 'saude'),
  ...mockBusinessesEsporte.filter(b => b.type === 'esporte'),
  ...mockBusinessesBeleza.filter(b => b.type === 'beleza'),
].sort((a, b) => (b.rating ?? 0) - (a.rating ?? 0));

const typeTabs = [
  { id: 'all',                    label: 'Todos',             count: allBusinesses.length },
  { id: 'digital',                label: 'Agências Digitais', count: mockBusinesses.filter(b => b.type === 'digital').length },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length },
  { id: 'gastronomia',            label: 'Gastronomia',        count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length },
  { id: 'saude',                  label: 'Saúde & Bem-Estar',  count: mockBusinessesSaude.filter(b => b.type === 'saude').length },
  { id: 'esporte',                label: 'Esporte & Lazer',    count: mockBusinessesEsporte.filter(b => b.type === 'esporte').length },
  { id: 'beleza',                 label: 'Beleza & Estética',  count: mockBusinessesBeleza.filter(b => b.type === 'beleza').length },
];

const ltCategories = [
  { id: 'digital',                label: 'Agências Digitais', icon: '💻', count: mockBusinesses.filter(b => b.type === 'digital').length,                cover: mockBusinesses[0].cover },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', icon: '🏛️', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length, cover: mockBusinessesB2B[0].cover },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   icon: '🔧', count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length,      cover: mockBusinessesTec[0].cover },
  { id: 'gastronomia',            label: 'Gastronomia',        icon: '🍽️', count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length,         cover: mockBusinessesGastro[0].cover },
  { id: 'saude',                  label: 'Saúde & Bem-Estar',  icon: '🏥', count: mockBusinessesSaude.filter(b => b.type === 'saude').length,                cover: mockBusinessesSaude[0].cover },
  { id: 'esporte',                label: 'Esporte & Lazer',    icon: '🏋️', count: mockBusinessesEsporte.filter(b => b.type === 'esporte').length,            cover: mockBusinessesEsporte[0].cover },
  { id: 'beleza',                 label: 'Beleza & Estética',  icon: '✨', count: mockBusinessesBeleza.filter(b => b.type === 'beleza').length,               cover: mockBusinessesBeleza[0].cover },
];

const carouselTabs = [
  { id: 'all',                    label: 'Todos',              count: allBusinesses.length,                                                              cover: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=400&auto=format&fit=crop' },
  { id: 'digital',                label: 'Agências Digitais',  count: mockBusinesses.filter(b => b.type === 'digital').length,                            cover: mockBusinesses[0].cover },
  { id: 'servicos-profissionais', label: 'Profissionais B2B',  count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length,           cover: mockBusinessesB2B[0].cover },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',    count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length,                cover: mockBusinessesTec[0].cover },
  { id: 'gastronomia',            label: 'Gastronomia',         count: mockBusinessesGastro.filter(b => b.type === 'gastronomia').length,                  cover: mockBusinessesGastro[0].cover },
  { id: 'saude',                  label: 'Saúde & Bem-Estar',   count: mockBusinessesSaude.filter(b => b.type === 'saude').length,                        cover: mockBusinessesSaude[0].cover },
  { id: 'esporte',                label: 'Esporte & Lazer',     count: mockBusinessesEsporte.filter(b => b.type === 'esporte').length,                    cover: mockBusinessesEsporte[0].cover },
  { id: 'beleza',                 label: 'Beleza & Estética',   count: mockBusinessesBeleza.filter(b => b.type === 'beleza').length,                      cover: mockBusinessesBeleza[0].cover },
];

const subcatGroups = [
  {
    typeId: 'digital',
    cover: mockBusinesses[0].cover,
    subs: [
      { name: 'Marketing Digital', icon: '📣' },
      { name: 'Dev Web & Apps',    icon: '💻' },
      { name: 'Design Visual',     icon: '🎨' },
      { name: 'Tráfego & Growth',  icon: '📈' },
      { name: 'Automação',         icon: '⚙️' },
    ],
  },
  {
    typeId: 'servicos-profissionais',
    cover: mockBusinessesB2B[0].cover,
    subs: [
      { name: 'Contabilidade', icon: '📊' },
      { name: 'Imobiliária',   icon: '🏠' },
      { name: 'Seguros',       icon: '🛡️' },
      { name: 'Consultoria',   icon: '💼' },
      { name: 'RH',            icon: '👥' },
    ],
  },
  {
    typeId: 'servicos-tecnicos',
    cover: mockBusinessesTec[0].cover,
    subs: [
      { name: 'Reforma & Construção', icon: '🔨' },
      { name: 'Eletricidade',         icon: '⚡' },
      { name: 'Ar-Condicionado',      icon: '❄️' },
      { name: 'Pet Care',             icon: '🐾' },
      { name: 'Transporte',           icon: '🚚' },
    ],
  },
  {
    typeId: 'gastronomia',
    cover: mockBusinessesGastro[0].cover,
    subs: [
      { name: 'Restaurantes',     icon: '🍽️' },
      { name: 'Cafeterias',       icon: '☕' },
      { name: 'Delivery',         icon: '🛵' },
      { name: 'Eventos & Buffet', icon: '🎉' },
      { name: 'Bares & Drinks',   icon: '🍹' },
    ],
  },
  {
    typeId: 'saude',
    cover: mockBusinessesSaude[0].cover,
    subs: [
      { name: 'Odontologia',   icon: '🦷' },
      { name: 'Dermatologia',  icon: '🔬' },
      { name: 'Psicologia',    icon: '🧠' },
      { name: 'Fisioterapia',  icon: '🏃' },
      { name: 'Nutrição',      icon: '🥗' },
      { name: 'Clínica Geral', icon: '🩺' },
    ],
  },
  {
    typeId: 'esporte',
    cover: mockBusinessesEsporte[0].cover,
    subs: [
      { name: 'Musculação / Academias',        icon: '🏋️' },
      { name: 'Beach Tennis / Areia',          icon: '🎾' },
      { name: 'Crossfit / Funcional',          icon: '⚡' },
      { name: 'Yoga & Pilates',                icon: '🧘' },
      { name: 'Artes Marciais',                icon: '🥋' },
      { name: 'Natação',                       icon: '🏊' },
    ],
  },
];

const urgenciaConfig: Record<string, { label: string; color: string }> = {
  'sim-24h':       { label: '⚡ Urgência 24h',    color: 'bg-red-500 text-white' },
  'sim-comercial': { label: '✓ Atende urgências', color: 'bg-amber-500 text-white' },
};

function getBusinessUrl(b: (typeof allBusinesses)[0]) {
  if (b.type === 'servicos-profissionais') return `/servicos-profissionais/${b.slug}`;
  if (b.type === 'servicos-tecnicos')      return `/servicos-tecnicos/${b.slug}`;
  if (b.type === 'gastronomia')            return `/gastronomia/${b.slug}`;
  if (b.type === 'saude')                  return `/saude/${b.slug}`;
  if (b.type === 'esporte')               return `/esporte/${b.slug}`;
  return `/digital/${b.slug}`;
}

// Deriva o tipo de cozinha a partir da categoria, para o filtro de gastronomia
// TODO: WP — virá de acf.tipo_cozinha (select/radio field no CPT listing)
function getCozinhaKey(b: (typeof allBusinesses)[0]): string {
  if (b.type !== 'gastronomia') return '';
  const cat = b.category.toLowerCase();
  if (cat.includes('grill') || cat.includes('churrasco') || cat.includes('carne')) return 'carnes';
  if (cat.includes('cafe') || cat.includes('café') || cat.includes('padaria')) return 'cafe';
  if (cat.includes('brasileira')) return 'brasileira';
  if (cat.includes('italiana')) return 'italiana';
  if (cat.includes('japonesa')) return 'japonesa';
  return '';
}

// Deriva a especialidade médica a partir da categoria, para o filtro de saúde
// TODO: WP — virá de acf.especialidade (select field no CPT listing)
function getEspecialidadeKey(b: (typeof allBusinesses)[0]): string {
  if (b.type !== 'saude') return '';
  const cat = b.category.toLowerCase();
  if (cat.includes('odonto') || cat.includes('dental')) return 'odontologia';
  if (cat.includes('derma'))                             return 'dermatologia';
  if (cat.includes('psico') || cat.includes('mental'))  return 'psicologia';
  if (cat.includes('fisio'))                             return 'fisioterapia';
  if (cat.includes('exame') || cat.includes('lab'))      return 'exames';
  if (cat.includes('família') || cat.includes('familia') || cat.includes('clínica geral')) return 'clinica-familia';
  return '';
}

// Mapeia categoria do negócio → label da subcategoria, para filtro exato
// TODO: WP — virá de acf.subcategoria (taxonomy field no CPT listing)
function getSubcatKey(b: (typeof allBusinesses)[0]): string {
  const cat = b.category.toLowerCase();
  // Digital
  if (cat.includes('marketing'))                                                    return 'Marketing Digital';
  if (cat.includes('desenvolvimento') || cat.includes('web') || cat.includes('mobile')) return 'Dev Web & Apps';
  if (cat.includes('design') || cat.includes('branding'))                          return 'Design Visual';
  if (cat.includes('tráfego') || cat.includes('trafego') || cat.includes('growth')) return 'Tráfego & Growth';
  if (cat.includes('automação') || cat.includes('automacao'))                      return 'Automação';
  // Profissionais B2B
  if (cat.includes('contab'))                                                       return 'Contabilidade';
  if (cat.includes('imob'))                                                         return 'Imobiliária';
  if (cat.includes('seguro'))                                                       return 'Seguros';
  if (cat.includes('consultoria'))                                                  return 'Consultoria';
  if (cat.includes('rh') || cat.includes('talentos') || cat.includes('recursos'))  return 'RH';
  // Técnicos & Casa
  if (cat.includes('reforma') || cat.includes('construção') || cat.includes('construcao')) return 'Reforma & Construção';
  if (cat.includes('elétric') || cat.includes('eletric'))                          return 'Eletricidade';
  if (cat.includes('climatiz') || cat.includes('refrigeração') || cat.includes('ar-condicionado')) return 'Ar-Condicionado';
  if (cat.includes('pet') || cat.includes('veterinár'))                            return 'Pet Care';
  if (cat.includes('transport') || cat.includes('mudança'))                        return 'Transporte';
  // Gastronomia
  if (cat.includes('restaurante') || cat.includes('grill') || cat.includes('churrasco')) return 'Restaurantes';
  if (cat.includes('cafe') || cat.includes('café') || cat.includes('padaria'))     return 'Cafeterias';
  if (cat.includes('delivery') || cat.includes('marmita'))                         return 'Delivery';
  if (cat.includes('evento') || cat.includes('buffet'))                            return 'Eventos & Buffet';
  if (cat.includes('bar') || cat.includes('drink') || cat.includes('cocktail'))    return 'Bares & Drinks';
  // Saúde
  if (cat.includes('odonto') || cat.includes('dental'))                            return 'Odontologia';
  if (cat.includes('derma'))                                                        return 'Dermatologia';
  if (cat.includes('psico') || cat.includes('mental'))                             return 'Psicologia';
  if (cat.includes('fisio'))                                                        return 'Fisioterapia';
  if (cat.includes('nutri'))                                                        return 'Nutrição';
  if (cat.includes('clínica geral') || cat.includes('clinica') || cat.includes('família')) return 'Clínica Geral';
  // Esporte & Lazer
  if (cat.includes('academia') || cat.includes('musculação') || cat.includes('musculacao')) return 'Musculação / Academias';
  if (cat.includes('beach tennis') || cat.includes('areia'))                       return 'Beach Tennis / Areia';
  if (cat.includes('crossfit') || cat.includes('funcional'))                       return 'Crossfit / Funcional';
  if (cat.includes('yoga') || cat.includes('pilates'))                             return 'Yoga & Pilates';
  if (cat.includes('artes marciais') || cat.includes('luta') || cat.includes('jiu'))       return 'Artes Marciais';
  if (cat.includes('natação') || cat.includes('natacao'))                          return 'Natação';
  // Beleza & Estética
  if (cat.includes('barbearia') || cat.includes('barba') || cat.includes('corte masculino')) return 'Cabelo & Barbearia';
  if (cat.includes('salão') || cat.includes('salao') || cat.includes('cabele'))   return 'Cabelo & Barbearia';
  if (cat.includes('manicure') || cat.includes('pedicure') || cat.includes('nail')) return 'Manicure & Pedicure';
  if (cat.includes('depilação') || cat.includes('depilacao'))                      return 'Depilação';
  if (cat.includes('estétic') || cat.includes('estet') || cat.includes('spa') || cat.includes('sobrancelha')) return 'Estética Facial';
  if (cat.includes('maquiagem') || cat.includes('makeup'))                         return 'Maquiagem';
  return '';
}

// Deriva a modalidade esportiva a partir da categoria, para o filtro condicional
// TODO: WP — virá de acf.modalidade (checkbox/select field no CPT listing)
function getModalidadeKey(b: (typeof allBusinesses)[0]): string {
  if (b.type !== 'esporte') return '';
  const cat = b.category.toLowerCase();
  if (cat.includes('academia') || cat.includes('musculação') || cat.includes('musculacao')) return 'musculacao';
  if (cat.includes('beach tennis') || cat.includes('areia'))  return 'beach-tennis';
  if (cat.includes('crossfit') || cat.includes('funcional'))  return 'crossfit';
  if (cat.includes('yoga') || cat.includes('pilates'))        return 'yoga-pilates';
  if (cat.includes('artes marciais') || cat.includes('luta')) return 'artes-marciais';
  if (cat.includes('natação') || cat.includes('natacao'))     return 'natacao';
  return '';
}

// TODO: WP — este array virá de uma Custom Taxonomy 'empreendimento' do WordPress
// Substituir por: await fetch(`${WP_API}/wp-json/wp/v2/empreendimento`)
const empreendimentos = [
  'Cidade Jardim', 'Rio2', 'Ilha Pura', 'Union Square',
  'Worldwide Offices', 'CEO', 'Metropolitan',
];

// TODO: WP — o campo 'empreendimento' virá do meta field (ACF) no CPT 'listing'
// Substituir por: post.acf.empreendimento || post.meta._empreendimento
// Por enquanto, atribuição estática cíclica para validação de layout
const bizEmpreendimento: Record<string, string> = Object.fromEntries(
  allBusinesses.map((b, i) => [b.slug, empreendimentos[i % empreendimentos.length]])
);
---

<Layout
  title="Serviços — HUBMETROPOLITANO"
  description="Agências digitais, profissionais B2B e técnicos especializados verificados na Barra da Tijuca."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="text-hub-gelo py-14 relative overflow-hidden bg-hub-pavao-profundo">
      <!-- Imagem de fundo: arquitetura corporativa moderna -->
      <img
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1920&auto=format&fit=crop"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-center opacity-35"
        loading="eager"
      />
      <!-- Overlay gradiente para legibilidade -->
      <div class="absolute inset-0 bg-gradient-to-r from-hub-pavao-profundo/90 via-hub-pavao-profundo/60 to-hub-pavao-profundo/30"></div>

      <!-- Conteúdo -->
      <div class="container mx-auto px-4 lg:px-8 relative z-10">
        <h5 class="text-hub-cobre mb-3">Vitrine de Negócios</h5>
        <h1 class="mb-6 max-w-2xl font-black text-hub-gelo">
          <span class="text-hub-cobre">Serviços</span><br />
          <span class="text-white">Verificados</span>
        </h1>
        <div class="relative max-w-2xl">
          <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-hub-chumbo/40 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Buscar agência, serviço, especialidade..."
            class="w-full bg-white text-hub-chumbo font-body text-lg pl-14 pr-6 py-4 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-hub-cobre/50 transition-shadow"
          />
        </div>
      </div>
    </section>

    <!-- Category Carousel -->
    <div class="bg-white border-b border-hub-gelo sticky top-[64px] z-20 shadow-sm">
      <div class="overflow-x-auto py-5" style="scrollbar-width: none; -ms-overflow-style: none;">
        <div class="container mx-auto px-4 lg:px-8">
        <div class="flex gap-3">
          {carouselTabs.map((t, i) => (
            <button
              data-type-icon={t.id}
              class={`type-icon-btn relative flex-1 min-w-[110px] h-[68px] rounded-2xl overflow-hidden cursor-pointer transition-all duration-300${i === 0 ? ' is-active' : ''}`}
            >
              <img
                src={t.cover}
                alt=""
                aria-hidden="true"
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <div class="type-overlay absolute inset-0 bg-hub-pavao-profundo"></div>
              <div class="relative z-10 flex flex-col items-center justify-center h-full gap-0.5 px-2">
                <span class="font-head font-bold text-white uppercase tracking-wide text-sm leading-tight text-center">{t.label}</span>
                <span class="font-body text-white/60 text-[11px]">{t.count} negócios</span>
              </div>
            </button>
          ))}
        </div>
        </div>
      </div>
      <!-- Mobile search — aparece quando o hero sai da viewport (só mobile) -->
      <div id="mobile-top-search" class="lg:hidden hidden px-4 pb-3 pt-1">
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-hub-chumbo/40 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="mobile-search-input"
            type="text"
            placeholder="Buscar serviço, especialidade..."
            class="w-full bg-hub-gelo text-hub-chumbo font-body text-sm pl-9 pr-4 py-2.5 rounded-full border border-hub-gelo/80 focus:outline-none focus:ring-2 focus:ring-hub-cobre/40 transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Layout: sidebar + grid de resultados -->
    <div class="bg-hub-gelo min-h-screen">
    <div class="container mx-auto flex items-start">

      <!-- Backdrop mobile drawer -->
      <div id="drawer-backdrop" class="fixed inset-0 z-30 bg-black/50 backdrop-blur-sm lg:hidden" style="display:none" aria-hidden="true"></div>

      <!-- ── Sidebar de Filtros ─────────────────────────────────────── -->
      <aside id="sidebar" class="bg-white border-r border-hub-gelo shrink-0">

        <!-- Cabeçalho do bottom sheet (só mobile) -->
        <div class="lg:hidden flex flex-col items-center pt-3 pb-0">
          <!-- Drag handle -->
          <div class="w-10 h-1 rounded-full bg-hub-gelo mb-3"></div>
          <div class="flex items-center justify-between w-full px-5 pb-3 border-b border-hub-gelo">
            <span class="font-head font-bold text-hub-pavao uppercase tracking-wider text-sm">Todos os Filtros</span>
            <button id="close-drawer-btn" class="p-2 -mr-1 rounded-full hover:bg-hub-gelo transition-colors text-hub-chumbo/60" aria-label="Fechar filtros">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Filtros -->
        <div id="panel-filtros" class="flex-1 overflow-y-auto flex flex-col min-h-0">

          <div class="flex-1 pl-4 lg:pl-8 pr-4 py-4 flex flex-col gap-5">

            <!--
              Localização / Empreendimento
              TODO: WP — os itens desta lista virão de uma Custom Taxonomy 'empreendimento'
              Fetch: GET /wp-json/wp/v2/empreendimento?per_page=100
              Renderizar dinamicamente substituindo a lista estática abaixo
            -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Localização</p>
              <div class="flex flex-col gap-2">
                {empreendimentos.map(emp => (
                  <label class="flex items-center gap-2.5 cursor-pointer group min-h-[44px]">
                    <input
                      type="checkbox"
                      data-empreendimento-filter={emp}
                      class="empreendimento-cb w-4 h-4 rounded border-hub-gelo text-hub-pavao accent-hub-pavao cursor-pointer shrink-0"
                    />
                    <span class="font-body text-sm text-hub-chumbo/70 group-hover:text-hub-pavao transition-colors">{emp}</span>
                  </label>
                ))}
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- O que você procura? -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">O que você procura?</p>
              <div id="subcat-list" class="flex flex-wrap gap-1.5">
                <p class="font-body text-hub-chumbo/40 text-base py-1">Selecione um tipo acima</p>
              </div>
            </div>

            <!-- Tipo de Cozinha (só Gastronomia) — oculto por padrão -->
            <div id="cozinha-section" class="filter-collapsible">
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Tipo de Cozinha</p>
              <div class="flex flex-wrap gap-1.5">
                <button data-cozinha="" class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer bg-hub-pavao text-white border-hub-pavao">Todas</button>
                <button data-cozinha="brasileira" class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🍲 Brasileira</button>
                <button data-cozinha="italiana"   class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🍝 Italiana</button>
                <button data-cozinha="japonesa"   class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🍱 Japonesa</button>
                <button data-cozinha="carnes"     class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🥩 Carnes & Grills</button>
                <button data-cozinha="cafe"       class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">☕ Cafeteria</button>
                <button data-cozinha="fast-food"  class="cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🍔 Fast Food</button>
              </div>
            </div>

            <!-- Urgência (só LT3) — oculto por padrão -->
            <div id="urgencia-section" class="filter-collapsible">
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Urgência</p>
              <div class="flex flex-col gap-1.5">
                <button data-urgencia=""             class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors bg-hub-pavao text-white border-hub-pavao">Todas</button>
                <button data-urgencia="sim-24h"      class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">⚡ Urgência 24h</button>
                <button data-urgencia="sim-comercial" class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">✓ Horário comercial</button>
              </div>
            </div>

            <!-- Especialidades de Beleza (só Beleza & Estética) — oculto por padrão -->
            <div id="beleza-section" class="filter-collapsible">
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Especialidades de Beleza</p>
              <div class="flex flex-wrap gap-1.5">
                <button data-cat="" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer bg-hub-pavao text-white border-hub-pavao">Todas</button>
                <button data-cat="Cabelo & Barbearia" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">✂️ Cabelo & Barbearia</button>
                <button data-cat="Manicure & Pedicure" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">💅 Manicure & Pedicure</button>
                <button data-cat="Depilação" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">🌿 Depilação</button>
                <button data-cat="Estética Facial" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">✨ Estética Facial</button>
                <button data-cat="Maquiagem" class="subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao">💄 Maquiagem</button>
              </div>
            </div>

          </div>

          <!-- Botão Buscar (sticky bottom) -->
          <div class="shrink-0 pl-4 lg:pl-8 pr-4 py-4 bg-white border-t border-hub-gelo">
            <button id="apply-filters-btn" class="w-full bg-hub-pavao text-white font-head font-semibold uppercase tracking-wider text-base py-3 rounded-xl hover:bg-hub-pavao-profundo transition-colors flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              Buscar
            </button>
          </div>

        </div>

      </aside>

      <!-- ── Área de Resultados ────────────────────────────────────── -->
      <!-- TODO: WP — substituir allBusinesses pelo resultado da query ao WP REST API -->
      <div id="results-panel" class="flex-1 min-w-0 bg-hub-gelo">

        <!-- Compact bar: count + toggle -->
        <div class="sticky top-[176px] z-10 bg-hub-gelo/95 backdrop-blur-sm border-b border-hub-gelo/60 px-4 lg:px-5 py-3 flex items-center gap-3">
          <!-- Botão Filtros (só mobile) -->
          <button id="open-drawer-btn" class="lg:hidden flex items-center gap-1.5 min-h-[44px] px-3 bg-white border border-hub-gelo rounded-lg text-hub-chumbo/70 font-body text-sm hover:border-hub-pavao hover:text-hub-pavao transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
            </svg>
            Filtros
          </button>
          <p id="results-count" class="font-body text-hub-chumbo/50 text-sm whitespace-nowrap flex-1">
            {allBusinesses.length} encontrados
          </p>
          <div class="flex items-center gap-0.5 bg-white border border-hub-gelo rounded-lg p-1 shadow-sm shrink-0">
            <button id="view-grid" aria-label="Grid" class="p-1.5 rounded bg-hub-pavao text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
              </svg>
            </button>
            <button id="view-list" aria-label="Lista" class="p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Cards grid — responsivo: 1 col mobile / 2 tablet / 3 desktop -->
        <div id="listings-container" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 p-4 lg:py-6 lg:pr-8">
          {allBusinesses.map(b => (
            <div
              class="biz-card"
              data-type={b.type}
              data-category={b.category.toLowerCase()}
              data-title={b.title.toLowerCase()}
              data-rating={b.rating ?? 0}
              data-urgencia={b.atendeUrgencia ?? ''}
              data-empreendimento={bizEmpreendimento[b.slug]}
              data-cozinha={getCozinhaKey(b)}
              data-subcat={getSubcatKey(b)}
            >
              <BusinessCard business={b} />
            </div>
          ))}
        </div>

        <div id="no-results" class="px-6 py-16 text-center" style="display:none">
          <div class="w-16 h-16 rounded-full bg-hub-pavao-soft flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-hub-pavao/50">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
          <p class="font-head font-bold text-hub-pavao text-xl uppercase tracking-wide mb-2">Nenhum resultado</p>
          <p class="font-body text-hub-chumbo/60 text-sm leading-relaxed mb-6">
            Ainda não temos negócios nesta categoria no Hub.<br />
            Conhece alguém? <a href="/indicar" class="text-hub-cobre underline underline-offset-2 hover:text-hub-cobre-luminoso transition-colors">Indique aqui!</a>
          </p>
          <button id="clear-filters-btn" class="inline-flex items-center gap-2 bg-hub-pavao text-white font-head font-semibold uppercase tracking-wider text-sm px-5 py-3 rounded-full hover:bg-hub-pavao-profundo transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
            Limpar Filtros
          </button>
        </div>
      </div>

    </div>
    </div>
  </main>

  <Footer />

  <script is:inline>
  (function () {
    var subcategoriesByType = {
      all:                      [],
      digital:                  ['Marketing Digital', 'Dev Web & Apps', 'Design Visual', 'Tráfego & Growth', 'Automação'],
      'servicos-profissionais': ['Contabilidade', 'Imobiliária', 'Seguros', 'Consultoria', 'RH'],
      'servicos-tecnicos':      ['Reforma & Construção', 'Eletricidade', 'Ar-Condicionado', 'Pet Care', 'Transporte'],
      gastronomia:              ['Restaurantes', 'Cafeterias', 'Delivery', 'Eventos & Buffet', 'Bares & Drinks'],
      saude:                    ['Odontologia', 'Dermatologia', 'Psicologia', 'Fisioterapia', 'Nutrição', 'Clínica Geral'],
      esporte:                  ['Musculação / Academias', 'Beach Tennis / Areia', 'Crossfit / Funcional', 'Yoga & Pilates', 'Artes Marciais', 'Natação'],
      beleza:                   ['Salão de Beleza', 'Spa & Bem-Estar', 'Nail Art', 'Estética', 'Sobrancelhas'],
    };
    var typeColors = {
      digital:                '#B87333',
      'servicos-profissionais': '#004445',
      'servicos-tecnicos':    '#374151',
    };

    var state = { query: '', type: 'all', subcategory: '', urgencia: '', cozinha: '', empreendimentos: [], view: 'grid' };

    var searchInput     = document.getElementById('search-input');
    var listingsCont    = document.getElementById('listings-container');
    var resultsCount    = document.getElementById('results-count');
    var noResults       = document.getElementById('no-results');
    var viewGridBtn     = document.getElementById('view-grid');
    var viewListBtn     = document.getElementById('view-list');
    var cards           = document.querySelectorAll('.biz-card');
    var subcatList      = document.getElementById('subcat-list');
    var urgenciaSection = document.getElementById('urgencia-section');
    var cozinhaSection  = document.getElementById('cozinha-section');
    var belezaSection   = document.getElementById('beleza-section');

    /* ── filtros ────────────────────────────────────────────────── */
    function applyFilters() {
      var q          = state.query.toLowerCase();
      var t          = state.type;
      var sub        = state.subcategory.toLowerCase();
      var urg        = state.urgencia;
      var empFilter  = state.empreendimentos; // array de strings selecionadas
      var visible    = 0;

      cards.forEach(function (card) {
        var ct   = card.dataset.type           || '';
        var ccat = card.dataset.category       || '';
        var ctit = card.dataset.title          || '';
        var csub = card.dataset.subcat         || '';
        var curg = card.dataset.urgencia       || '';
        var cemp = card.dataset.empreendimento || '';
        var ccoz  = card.dataset.cozinha || '';
        var show = (t === 'all' || ct === t) &&
                   (!sub        || csub === sub) &&
                   (!q          || ctit.includes(q) || ccat.includes(q)) &&
                   (!urg        || curg === urg) &&
                   (!state.cozinha || ccoz === state.cozinha) &&
                   (empFilter.length === 0 || empFilter.indexOf(cemp) !== -1);

        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (resultsCount) resultsCount.textContent = visible + ' encontrados';
      if (noResults && listingsCont) {
        noResults.style.display     = visible === 0 ? 'block' : 'none';
        listingsCont.style.display  = visible === 0 ? 'none' : '';
      }
    }


    /* ── subcategorias (chips) ──────────────────────────────────── */
    function setSubcat(cat) {
      state.subcategory = cat;
      document.querySelectorAll('.subcat-item').forEach(function (el) {
        var active = el.dataset.cat === cat;
        el.className = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    function renderSubcatList(type) {
      if (!subcatList) return;
      var cats = subcategoriesByType[type] || [];
      subcatList.innerHTML = '';
      if (cats.length === 0) {
        subcatList.innerHTML = '<p class="font-body text-hub-chumbo/40 text-xs py-1 w-full">Selecione uma categoria acima</p>';
        return;
      }
      var allBtn = document.createElement('button');
      allBtn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer bg-hub-pavao text-white border-hub-pavao';
      allBtn.dataset.cat = '';
      allBtn.textContent = 'Todas';
      allBtn.addEventListener('click', function () { setSubcat(''); });
      subcatList.appendChild(allBtn);
      cats.forEach(function (cat) {
        var btn = document.createElement('button');
        btn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao';
        btn.dataset.cat = cat;
        btn.textContent = cat;
        btn.addEventListener('click', function () { setSubcat(cat); });
        subcatList.appendChild(btn);
      });
    }

    /* ── urgência ───────────────────────────────────────────────── */
    function setUrgencia(val) {
      state.urgencia = val;
      document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
        var active = btn.dataset.urgencia === val;
        btn.className = 'urgencia-btn text-left px-3 py-2.5 rounded-lg border font-body text-base transition-colors ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setUrgencia(btn.dataset.urgencia || ''); });
    });

    /* ── tipo de cozinha (só Gastronomia) ───────────────────────── */
    function setCozinha(val) {
      state.cozinha = val;
      document.querySelectorAll('.cozinha-btn').forEach(function (btn) {
        var active = btn.dataset.cozinha === val;
        btn.className = 'cozinha-btn px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.cozinha-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setCozinha(btn.dataset.cozinha || ''); });
    });

    /* ── botão buscar — aplica e fecha o drawer no mobile ──────── */
    var applyBtn = document.getElementById('apply-filters-btn');
    if (applyBtn) applyBtn.addEventListener('click', function () {
      applyFilters();
      if (window.innerWidth < 1024) closeDrawer();
    });

    function activateType(newType) {
      state.type        = newType;
      state.subcategory = '';
      state.urgencia    = '';
      state.cozinha     = '';

      renderSubcatList(newType);
      if (urgenciaSection) urgenciaSection.classList.toggle('filter-visible', newType === 'servicos-tecnicos');
      if (cozinhaSection)  cozinhaSection.classList.toggle('filter-visible', newType === 'gastronomia');
      if (belezaSection)   belezaSection.classList.toggle('filter-visible', newType === 'beleza');

      setUrgencia('');
      setCozinha('');
      applyFilters();
    }

    /* ── carousel de categorias ─────────────────────────────────── */
    function updateIconBar(newType) {
      document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.typeIcon === newType);
      });
      // Rola até o card ativo
      var activeBtn = document.querySelector('.type-icon-btn.is-active');
      if (activeBtn) activeBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var t = btn.dataset.typeIcon || 'all';
        updateIconBar(t);
        activateType(t);
      });
    });

    /* ── busca ──────────────────────────────────────────────────── */
    var searchTimer;
    if (searchInput) {
      searchInput.addEventListener('input', function (e) {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function () { state.query = e.target.value.trim(); applyFilters(); }, 200);
      });
    }

    /* ── grid / lista ───────────────────────────────────────────── */
    if (viewGridBtn) {
      viewGridBtn.addEventListener('click', function () {
        state.view = 'grid';
        if (listingsCont) listingsCont.classList.remove('is-list-view');
        viewGridBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewListBtn) viewListBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }
    if (viewListBtn) {
      viewListBtn.addEventListener('click', function () {
        state.view = 'list';
        if (listingsCont) listingsCont.classList.add('is-list-view');
        viewListBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewGridBtn) viewGridBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }

    /* ── filtro empreendimento (checkboxes) ─────────────────────── */
    // TODO: WP — quando os dados vierem da API, os checkboxes serão gerados dinamicamente
    document.querySelectorAll('.empreendimento-cb').forEach(function (cb) {
      cb.addEventListener('change', function () {
        var emp = cb.dataset.empreendimentoFilter || '';
        if (cb.checked) {
          if (state.empreendimentos.indexOf(emp) === -1) state.empreendimentos.push(emp);
        } else {
          state.empreendimentos = state.empreendimentos.filter(function (e) { return e !== emp; });
        }
        applyFilters();
      });
    });

    /* ── drawer mobile ──────────────────────────────────────────── */
    var sidebar         = document.getElementById('sidebar');
    var backdrop        = document.getElementById('drawer-backdrop');
    var openDrawerBtn   = document.getElementById('open-drawer-btn');
    var closeDrawerBtn  = document.getElementById('close-drawer-btn');

    function openDrawer() {
      if (sidebar)  sidebar.classList.add('drawer-open');
      if (backdrop) backdrop.style.display = '';
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      if (sidebar)  sidebar.classList.remove('drawer-open');
      if (backdrop) backdrop.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (openDrawerBtn)  openDrawerBtn.addEventListener('click', openDrawer);
    if (closeDrawerBtn) closeDrawerBtn.addEventListener('click', closeDrawer);
    if (backdrop)       backdrop.addEventListener('click', closeDrawer);

    /* ── mobile sticky search (IntersectionObserver) ────────────── */
    var mobileTopSearch  = document.getElementById('mobile-top-search');
    var mobileSearchInput = document.getElementById('mobile-search-input');

    if (searchInput && mobileTopSearch && window.IntersectionObserver) {
      var heroObs = new IntersectionObserver(function (entries) {
        mobileTopSearch.classList.toggle('hidden', entries[0].isIntersecting);
      }, { threshold: 0 });
      heroObs.observe(searchInput);
    }

    if (mobileSearchInput) {
      mobileSearchInput.addEventListener('input', function (e) {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function () {
          state.query = e.target.value.trim();
          if (searchInput) searchInput.value = state.query;
          applyFilters();
        }, 200);
      });
    }

    /* ── limpar filtros ─────────────────────────────────────────── */
    var clearFiltersBtn = document.getElementById('clear-filters-btn');
    if (clearFiltersBtn) {
      clearFiltersBtn.addEventListener('click', function () {
        state.query = ''; state.type = 'all'; state.subcategory = '';
        state.urgencia = ''; state.cozinha = ''; state.empreendimentos = [];
        if (searchInput) searchInput.value = '';
        if (mobileSearchInput) mobileSearchInput.value = '';
        document.querySelectorAll('.empreendimento-cb').forEach(function (cb) { cb.checked = false; });
        if (urgenciaSection) urgenciaSection.classList.remove('filter-visible');
        if (cozinhaSection)  cozinhaSection.classList.remove('filter-visible');
        if (belezaSection)   belezaSection.classList.remove('filter-visible');
        updateIconBar('all');
        renderSubcatList('all');
        setUrgencia('');
        setCozinha('');
        applyFilters();
      });
    }

    /* ── init ───────────────────────────────────────────────────── */
    updateIconBar('all');
    renderSubcatList('all');
    setUrgencia('');
    applyFilters();

  })();
  </script>
</Layout>

