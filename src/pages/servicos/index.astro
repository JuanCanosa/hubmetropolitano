---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { mockBusinesses, mockBusinessesB2B, mockBusinessesTec } from '../../utils/mockBusinesses';

const allBusinesses = [
  ...mockBusinesses.filter(b => b.type === 'digital'),
  ...mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais'),
  ...mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos'),
];

const typeTabs = [
  { id: 'all',                    label: 'Todos',             count: allBusinesses.length },
  { id: 'digital',                label: 'Agências Digitais', count: mockBusinesses.filter(b => b.type === 'digital').length },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length },
];

const ltCategories = [
  { id: 'digital',                label: 'Agências Digitais', icon: '💻', count: mockBusinesses.filter(b => b.type === 'digital').length,                cover: mockBusinesses[0].cover },
  { id: 'servicos-profissionais', label: 'Profissionais B2B', icon: '🏛️', count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length, cover: mockBusinessesB2B[0].cover },
  { id: 'servicos-tecnicos',      label: 'Técnicos & Casa',   icon: '🔧', count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length,      cover: mockBusinessesTec[0].cover },
];

const subcatGroups = [
  {
    typeId: 'digital',
    cover: mockBusinesses[0].cover,
    subs: [
      { name: 'Marketing Digital', icon: '📣' },
      { name: 'Dev Web & Apps',    icon: '💻' },
      { name: 'Design Visual',     icon: '🎨' },
      { name: 'Tráfego & Growth',  icon: '📈' },
      { name: 'Automação',         icon: '⚙️' },
    ],
  },
  {
    typeId: 'servicos-profissionais',
    cover: mockBusinessesB2B[0].cover,
    subs: [
      { name: 'Contabilidade', icon: '📊' },
      { name: 'Imobiliária',   icon: '🏠' },
      { name: 'Seguros',       icon: '🛡️' },
      { name: 'Consultoria',   icon: '💼' },
      { name: 'RH',            icon: '👥' },
    ],
  },
  {
    typeId: 'servicos-tecnicos',
    cover: mockBusinessesTec[0].cover,
    subs: [
      { name: 'Reforma & Construção', icon: '🔨' },
      { name: 'Eletricidade',         icon: '⚡' },
      { name: 'Ar-Condicionado',      icon: '❄️' },
      { name: 'Pet Care',             icon: '🐾' },
      { name: 'Transporte',           icon: '🚚' },
    ],
  },
];

const urgenciaConfig: Record<string, { label: string; color: string }> = {
  'sim-24h':       { label: '⚡ Urgência 24h',    color: 'bg-red-500 text-white' },
  'sim-comercial': { label: '✓ Atende urgências', color: 'bg-amber-500 text-white' },
};

function getBusinessUrl(b: (typeof allBusinesses)[0]) {
  if (b.type === 'servicos-profissionais') return `/servicos-profissionais/${b.slug}`;
  if (b.type === 'servicos-tecnicos')      return `/servicos-tecnicos/${b.slug}`;
  return `/digital/${b.slug}`;
}
---

<Layout
  title="Serviços — HUBMETROPOLITANO"
  description="Agências digitais, profissionais B2B e técnicos especializados verificados na Barra da Tijuca."
>
  <link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <Header />

  <main>
    <!-- Hero compacto -->
    <div class="bg-hub-pavao-profundo py-10 lg:py-14">
      <div class="container mx-auto px-4 lg:px-8 lg:max-w-6xl">
        <h5 class="text-hub-cobre mb-3">Vitrine de Negócios</h5>
        <h1 class="text-white mb-6 max-w-2xl">
          Serviços<br /><span class="text-hub-cobre">Verificados</span>
        </h1>
        <div class="relative max-w-2xl">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-hub-chumbo/40 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Buscar agência, serviço, especialidade..."
            class="w-full bg-white text-hub-chumbo font-body text-base pl-12 pr-4 py-3.5 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-hub-cobre transition-shadow"
          />
        </div>
      </div>
    </div>

    <!-- Top icon bar: listing types -->
    <div class="bg-white border-b border-hub-gelo sticky top-[64px] z-20 shadow-sm">
      <div class="flex items-center gap-3 overflow-x-auto px-6 py-4" style="scrollbar-width: none; -ms-overflow-style: none;">
        {[
          { id: 'all',                    icon: '🏢', label: 'Todos',              count: allBusinesses.length },
          { id: 'digital',                icon: '💻', label: 'Agências Digitais',   count: mockBusinesses.filter(b => b.type === 'digital').length },
          { id: 'servicos-profissionais', icon: '🏛️', label: 'Profissionais B2B',   count: mockBusinessesB2B.filter(b => b.type === 'servicos-profissionais').length },
          { id: 'servicos-tecnicos',      icon: '🔧', label: 'Técnicos & Casa',     count: mockBusinessesTec.filter(b => b.type === 'servicos-tecnicos').length },
        ].map((t, i) => (
          <button
            data-type-icon={t.id}
            class={`type-icon-btn flex items-center gap-3 px-5 py-2.5 rounded-full border shrink-0 transition-all duration-200 ${
              i === 0
                ? 'bg-hub-pavao border-hub-pavao text-white'
                : 'bg-white border-hub-gelo text-hub-chumbo/60 hover:border-hub-pavao hover:text-hub-pavao'
            }`}
          >
            <span class="text-lg leading-none">{t.icon}</span>
            <span class="font-head font-semibold uppercase tracking-wide text-base whitespace-nowrap">{t.label}</span>
            <span class="font-body text-sm opacity-60">({t.count})</span>
          </button>
        ))}
      </div>
    </div>

    <!-- 3-column layout -->
    <div class="flex items-start relative">

      <!-- ── Coluna 1: Sidebar Filtros / Categorias ────────────────── -->
      <div id="sidebar" class="hidden lg:flex w-[20%] shrink-0 flex-col bg-white border-r border-hub-gelo">

        <!-- Filtros -->
        <div id="panel-filtros" class="flex-1 overflow-y-auto flex flex-col min-h-0">

          <div class="flex-1 p-4 flex flex-col gap-5">

            <!-- O que você procura? -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">O que você procura?</p>
              <div id="subcat-list" class="flex flex-wrap gap-1.5">
                <p class="font-body text-hub-chumbo/40 text-base py-1">Selecione um tipo acima</p>
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- Avaliação -->
            <div>
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Avaliação</p>
              <div class="grid grid-cols-2 gap-1.5">
                <button data-rating="5"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★★★<br/><span class="text-sm text-hub-chumbo/40">5 estrelas</span></button>
                <button data-rating="4"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★★<br/><span class="text-sm text-hub-chumbo/40">4+ estrelas</span></button>
                <button data-rating="3"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★★<br/><span class="text-sm text-hub-chumbo/40">3+ estrelas</span></button>
                <button data-rating="2"   class="rating-btn col-span-1 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors leading-tight">★★<br/><span class="text-sm text-hub-chumbo/40">2+ estrelas</span></button>
                <button data-rating="0"   class="rating-btn col-span-2 text-center px-2 py-2.5 rounded-lg border border-hub-gelo font-body text-base bg-hub-pavao text-white border-hub-pavao transition-colors">Qualquer nota</button>
              </div>
            </div>

            <hr class="border-hub-gelo" />

            <!-- Urgência (só LT3) -->
            <div id="urgencia-section" class="hidden">
              <p class="font-head font-semibold uppercase tracking-widest text-base text-hub-chumbo/35 mb-3">Urgência</p>
              <div class="flex flex-col gap-1.5">
                <button data-urgencia=""             class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors bg-hub-pavao text-white border-hub-pavao">Todas</button>
                <button data-urgencia="sim-24h"      class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">⚡ Urgência 24h</button>
                <button data-urgencia="sim-comercial" class="urgencia-btn text-left px-3 py-2.5 rounded-lg border border-hub-gelo font-body text-base text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao transition-colors">✓ Horário comercial</button>
              </div>
              <hr class="border-hub-gelo mt-5" />
            </div>

          </div>

          <!-- Botão Buscar (sticky bottom) -->
          <div class="shrink-0 p-4 bg-white border-t border-hub-gelo">
            <button id="apply-filters-btn" class="w-full bg-hub-pavao text-white font-head font-semibold uppercase tracking-wider text-base py-3 rounded-xl hover:bg-hub-pavao-profundo transition-colors flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              Buscar
            </button>
          </div>

        </div>

      </div>

      <!-- ── Coluna 2: Cards ────────────────────────────────────────── -->
      <div id="left-panel" class="w-full lg:w-[20%] shrink-0 bg-hub-gelo min-w-0">

        <!-- Compact bar: count + toggle -->
        <div class="sticky top-0 z-10 bg-hub-gelo/95 backdrop-blur-sm border-b border-hub-gelo/60 px-4 lg:px-5 py-3 flex items-center justify-between gap-3">
          <p id="results-count" class="font-body text-hub-chumbo/50 text-sm whitespace-nowrap">
            {allBusinesses.length} encontrados
          </p>
          <div class="flex items-center gap-0.5 bg-white border border-hub-gelo rounded-lg p-1 shadow-sm shrink-0">
            <button id="view-grid" aria-label="Grid" class="p-1.5 rounded bg-hub-pavao text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
              </svg>
            </button>
            <button id="view-list" aria-label="Lista" class="p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Cards grid -->
        <div id="listings-container" class="grid grid-cols-1 gap-4 p-4 lg:p-5">
          {allBusinesses.map(b => {
            const url      = getBusinessUrl(b);
            const urgencia = b.atendeUrgencia && b.atendeUrgencia !== 'nao' ? urgenciaConfig[b.atendeUrgencia] : null;
            const preview  = b.services.slice(0, 3);
            return (
              <a
                href={url}
                data-slug={b.slug}
                data-type={b.type}
                data-category={b.category.toLowerCase()}
                data-title={b.title.toLowerCase()}
                data-lat={b.lat}
                data-lng={b.lng}
                data-rating={b.rating ?? 0}
                data-urgencia={b.atendeUrgencia ?? ''}
                class="biz-card group flex flex-col bg-white rounded-2xl border border-hub-gelo shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
              >
                <div class="card-cover relative h-44 overflow-hidden bg-hub-pavao-profundo shrink-0">
                  <img src={b.cover} alt={b.title} loading="lazy"
                    class="w-full h-full object-cover opacity-85 group-hover:scale-105 transition-transform duration-500" />
                  <div class="absolute inset-0 bg-gradient-to-t from-hub-pavao-profundo/80 via-hub-pavao-profundo/20 to-transparent" />

                  <span class="absolute top-3 right-3 bg-hub-cobre text-white text-[10px] font-head font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full">
                    {b.category.split(' ')[0]}
                  </span>

                  {urgencia && (
                    <span class={`absolute top-3 left-3 text-xs font-body font-semibold px-2.5 py-1 rounded-full ${urgencia.color}`}>
                      {urgencia.label}
                    </span>
                  )}

                  <span class="absolute bottom-3 right-3 inline-flex items-center gap-1 bg-white/90 backdrop-blur-sm text-hub-pavao text-[10px] font-body font-bold px-2 py-1 rounded-full shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 shrink-0">
                      <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
                    </svg>
                    Verificado
                  </span>

                  {b.logo ? (
                    <img src={b.logo} alt={b.title} class="absolute bottom-3 left-3 w-10 h-10 rounded-full border-2 border-white object-cover bg-white shadow" />
                  ) : (
                    <div class="absolute bottom-3 left-3 w-10 h-10 rounded-full border-2 border-white bg-hub-pavao flex items-center justify-center shadow">
                      <span class="text-white font-head font-bold text-sm">{b.title.charAt(0)}</span>
                    </div>
                  )}
                </div>

                <div class="card-body flex flex-col flex-1 p-5 gap-2">
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="font-head font-bold text-hub-chumbo group-hover:text-hub-cobre transition-colors text-lg uppercase tracking-wide leading-tight">
                      {b.title}
                    </h3>
                    {b.rating && (
                      <span class="shrink-0 font-body text-hub-cobre text-sm font-semibold">★ {b.rating}</span>
                    )}
                  </div>

                  <p class="font-body text-sm text-hub-chumbo/60 leading-snug">{b.tagline}</p>

                  {b.location && (
                    <div class="flex items-center gap-1.5 text-hub-chumbo/40 text-xs font-body">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                        <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
                      </svg>
                      {b.location}
                    </div>
                  )}

                  <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
                    {preview.map(s => (
                      <span class="inline-flex items-center gap-1 bg-hub-gelo text-hub-chumbo/70 text-xs font-body px-2.5 py-1 rounded-full">
                        <span>{s.icon}</span><span>{s.name}</span>
                      </span>
                    ))}
                    {b.services.length > 3 && (
                      <span class="inline-flex items-center bg-hub-pavao-soft text-hub-pavao text-xs font-body px-2.5 py-1 rounded-full">
                        +{b.services.length - 3}
                      </span>
                    )}
                  </div>
                </div>

                <div class="card-footer px-5 pb-4 pt-0">
                  <span class="inline-flex items-center gap-1.5 text-hub-cobre text-sm font-body group-hover:gap-3 transition-all">
                    Ver perfil completo
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>

        <div id="no-results" class="hidden px-6 py-20 text-center">
          <p class="font-head font-bold text-hub-pavao text-xl uppercase mb-2">Nenhum resultado</p>
          <p class="font-body text-hub-chumbo/50 text-sm">Tente outros termos ou remova os filtros.</p>
        </div>
      </div>

      <!-- ── Coluna 3: Mapa ─────────────────────────────────────────── -->
      <div id="map-panel" class="hidden lg:block w-[60%] shrink-0 sticky">
        <div id="map" class="w-full h-full"></div>
      </div>

    </div>
  </main>

  <Footer />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script is:inline>
  (function () {
    var subcategoriesByType = {
      all:                    [],
      digital:                ['Marketing Digital', 'Dev Web & Apps', 'Design Visual', 'Tráfego & Growth', 'Automação'],
      'servicos-profissionais': ['Contabilidade', 'Imobiliária', 'Seguros', 'Consultoria', 'RH'],
      'servicos-tecnicos':    ['Reforma & Construção', 'Eletricidade', 'Ar-Condicionado', 'Pet Care', 'Transporte'],
    };
    var typeColors = {
      digital:                '#B87333',
      'servicos-profissionais': '#004445',
      'servicos-tecnicos':    '#374151',
    };

    var state = { query: '', type: 'all', subcategory: '', minRating: 0, urgencia: '', view: 'grid' };

    var searchInput   = document.getElementById('search-input');
    var listingsCont  = document.getElementById('listings-container');
    var resultsCount  = document.getElementById('results-count');
    var noResults     = document.getElementById('no-results');
    var viewGridBtn   = document.getElementById('view-grid');
    var viewListBtn   = document.getElementById('view-list');
    var tabBtns       = document.querySelectorAll('.tab-btn');
    var cards         = document.querySelectorAll('.biz-card');
    var leftPanel     = document.getElementById('left-panel');
    var subcatList    = document.getElementById('subcat-list');
    var urgenciaSection = document.getElementById('urgencia-section');
    var panelFiltros    = document.getElementById('panel-filtros');

    /* ── offset dinâmico ────────────────────────────────────────── */
    function updateOffset() {
      var header  = document.querySelector('header');
      var iconBar = document.querySelector('.type-icon-btn')?.closest('div[class*="sticky"]');
      var h1 = header  ? header.offsetHeight  : 64;
      var h2 = iconBar ? iconBar.offsetHeight : 72;
      document.documentElement.style.setProperty('--map-offset', (h1 + h2) + 'px');
    }
    updateOffset();
    window.addEventListener('resize', updateOffset);

    /* ── mapa ───────────────────────────────────────────────────── */
    var map = L.map('map', { zoomControl: true, scrollWheelZoom: true })
               .setView([-22.999, -43.365], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    var markersLayer  = L.layerGroup().addTo(map);
    var markersBySlug = {};

    function makeIcon(color) {
      return L.divIcon({
        className: '',
        html: '<div style="width:34px;height:34px;background:' + color + ';border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;">' +
              '<div style="width:8px;height:8px;background:white;border-radius:50%;"></div></div>',
        iconSize: [34, 34], iconAnchor: [17, 17], popupAnchor: [0, -18],
      });
    }

    function buildMarker(card) {
      var lat  = parseFloat(card.dataset.lat  || '');
      var lng  = parseFloat(card.dataset.lng  || '');
      var slug = card.dataset.slug || '';
      var type = card.dataset.type || '';
      if (!lat || !lng) return null;
      var h3    = card.querySelector('h3');
      var title = h3 ? h3.textContent.trim() : slug;
      var cat   = (card.dataset.category || '').split(' ')[0];
      var color = typeColors[type] || '#B87333';
      var marker = L.marker([lat, lng], { icon: makeIcon(color) })
        .bindPopup(
          '<div class="map-popup"><div class="map-popup-title">' + title + '</div>' +
          '<div class="map-popup-cat">' + cat + '</div></div>',
          { maxWidth: 200, closeButton: false }
        );
      marker.on('click', function () {
        var el = document.querySelector('.biz-card[data-slug="' + slug + '"]');
        if (el && leftPanel) {
          var panelRect = leftPanel.getBoundingClientRect();
          var cardRect  = el.getBoundingClientRect();
          leftPanel.scrollTo({ top: cardRect.top - panelRect.top + leftPanel.scrollTop - 80, behavior: 'smooth' });
          el.classList.add('map-highlight');
          setTimeout(function () { el.classList.remove('map-highlight'); }, 1500);
        }
      });
      return marker;
    }

    /* ── filtros ────────────────────────────────────────────────── */
    function applyFilters() {
      var q         = state.query.toLowerCase();
      var t         = state.type;
      var sub       = state.subcategory.toLowerCase();
      var minRating = state.minRating;
      var urg       = state.urgencia;
      var visible   = 0;

      markersLayer.clearLayers();

      cards.forEach(function (card) {
        var ct     = card.dataset.type     || '';
        var ccat   = card.dataset.category || '';
        var ctitle = card.dataset.title    || '';
        var slug   = card.dataset.slug     || '';
        var crat   = parseFloat(card.dataset.rating   || '0');
        var curg   = card.dataset.urgencia || '';

        var show = (t === 'all' || ct === t) &&
                   (!sub  || ccat.includes(sub)) &&
                   (!q    || ctitle.includes(q) || ccat.includes(q)) &&
                   (!minRating || crat >= minRating) &&
                   (!urg  || curg === urg);

        card.style.display = show ? '' : 'none';
        if (show) {
          visible++;
          if (!markersBySlug[slug]) markersBySlug[slug] = buildMarker(card);
          if (markersBySlug[slug])  markersLayer.addLayer(markersBySlug[slug]);
        }
      });

      if (resultsCount) resultsCount.textContent = visible + ' encontrados';
      if (noResults && listingsCont) {
        noResults.style.display     = visible === 0 ? '' : 'none';
        listingsCont.style.display  = visible === 0 ? 'none' : '';
      }
    }


    /* ── subcategorias (chips) ──────────────────────────────────── */
    function setSubcat(cat) {
      state.subcategory = cat;
      document.querySelectorAll('.subcat-item').forEach(function (el) {
        var active = el.dataset.cat === cat;
        el.className = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    function renderSubcatList(type) {
      if (!subcatList) return;
      var cats = subcategoriesByType[type] || [];
      subcatList.innerHTML = '';
      if (cats.length === 0) {
        subcatList.innerHTML = '<p class="font-body text-hub-chumbo/40 text-xs py-1 w-full">Selecione uma categoria acima</p>';
        return;
      }
      var allBtn = document.createElement('button');
      allBtn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer bg-hub-pavao text-white border-hub-pavao';
      allBtn.dataset.cat = '';
      allBtn.textContent = 'Todas';
      allBtn.addEventListener('click', function () { setSubcat(''); });
      subcatList.appendChild(allBtn);
      cats.forEach(function (cat) {
        var btn = document.createElement('button');
        btn.className   = 'subcat-item px-3 py-1.5 rounded-full border font-body text-base transition-colors cursor-pointer border-hub-gelo text-hub-chumbo/60 hover:border-hub-cobre hover:text-hub-pavao';
        btn.dataset.cat = cat;
        btn.textContent = cat;
        btn.addEventListener('click', function () { setSubcat(cat); });
        subcatList.appendChild(btn);
      });
    }

    /* ── rating ─────────────────────────────────────────────────── */
    function setRating(minRating) {
      state.minRating = minRating;
      document.querySelectorAll('.rating-btn').forEach(function (btn) {
        var val = parseFloat(btn.dataset.rating || '0');
        var active = val === minRating;
        var isQualquer = val === 0;
        btn.className = 'rating-btn text-center px-2 py-2 rounded-lg border font-body text-base transition-colors leading-tight ' +
          (isQualquer ? 'col-span-2 ' : 'col-span-1 ') +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.rating-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setRating(parseFloat(btn.dataset.rating || '0')); });
    });

    /* ── urgência ───────────────────────────────────────────────── */
    function setUrgencia(val) {
      state.urgencia = val;
      document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
        var active = btn.dataset.urgencia === val;
        btn.className = 'urgencia-btn text-left px-3 py-2.5 rounded-lg border font-body text-base transition-colors ' +
          (active ? 'bg-hub-pavao text-white border-hub-pavao' : 'border-hub-gelo text-hub-chumbo/70 hover:border-hub-cobre hover:text-hub-pavao');
      });
      applyFilters();
    }

    document.querySelectorAll('.urgencia-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { setUrgencia(btn.dataset.urgencia || ''); });
    });

    /* ── botão buscar (só aplica filtros, já reativo por default) ── */
    var applyBtn = document.getElementById('apply-filters-btn');
    if (applyBtn) applyBtn.addEventListener('click', applyFilters);

    function activateType(newType) {
      state.type        = newType;
      state.subcategory = '';
      state.urgencia    = '';

      renderSubcatList(newType);
      if (urgenciaSection) urgenciaSection.style.display = newType === 'servicos-tecnicos' ? '' : 'none';
      setUrgencia('');
      applyFilters();
    }

    /* ── top icon bar ───────────────────────────────────────────── */
    function updateIconBar(newType) {
      document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
        var active = btn.dataset.typeIcon === newType;
        btn.className = 'type-icon-btn flex items-center gap-3 px-5 py-2.5 rounded-full border shrink-0 transition-all duration-200 ' +
          (active ? 'bg-hub-pavao border-hub-pavao text-white' : 'bg-white border-hub-gelo text-hub-chumbo/60 hover:border-hub-pavao hover:text-hub-pavao');
      });
    }

    document.querySelectorAll('.type-icon-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var t = btn.dataset.typeIcon || 'all';
        updateIconBar(t);
        activateType(t);
      });
    });

    /* ── busca ──────────────────────────────────────────────────── */
    var searchTimer;
    if (searchInput) {
      searchInput.addEventListener('input', function (e) {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function () { state.query = e.target.value.trim(); applyFilters(); }, 200);
      });
    }

    /* ── grid / lista ───────────────────────────────────────────── */
    if (viewGridBtn) {
      viewGridBtn.addEventListener('click', function () {
        state.view = 'grid';
        if (listingsCont) listingsCont.classList.remove('is-list-view');
        viewGridBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewListBtn) viewListBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }
    if (viewListBtn) {
      viewListBtn.addEventListener('click', function () {
        state.view = 'list';
        if (listingsCont) listingsCont.classList.add('is-list-view');
        viewListBtn.className = 'p-1.5 rounded bg-hub-pavao text-white transition-colors';
        if (viewGridBtn) viewGridBtn.className = 'p-1.5 rounded text-hub-chumbo/40 hover:text-hub-pavao transition-colors';
      });
    }

    /* ── hover card → popup mapa ────────────────────────────────── */
    cards.forEach(function (card) {
      var slug = card.dataset.slug;
      card.addEventListener('mouseenter', function () { var m = markersBySlug[slug]; if (m) m.openPopup(); });
      card.addEventListener('mouseleave', function () { var m = markersBySlug[slug]; if (m) m.closePopup(); });
    });

    /* ── init ───────────────────────────────────────────────────── */
    updateIconBar('all');
    renderSubcatList('all');
    setRating(0);
    setUrgencia('');
    applyFilters();
  })();
  </script>
</Layout>

<style>
  @media (min-width: 1024px) {
    #sidebar {
      position: sticky;
      top: var(--map-offset, 114px);
      height: calc(100vh - var(--map-offset, 114px));
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    #left-panel {
      height: calc(100vh - var(--map-offset, 114px));
      overflow-y: auto;
    }
    #map-panel {
      position: sticky;
      top: var(--map-offset, 114px);
      height: calc(100vh - var(--map-offset, 114px));
    }
  }

  #listings-container.is-list-view { grid-template-columns: 1fr !important; }
  #listings-container.is-list-view .biz-card { flex-direction: row; }
  #listings-container.is-list-view .card-cover { width: 160px; min-width: 160px; height: auto; min-height: 130px; }
  #listings-container.is-list-view .card-footer { display: none; }

  .biz-card.map-highlight {
    box-shadow: 0 0 0 3px #B87333, 0 12px 28px rgba(0,0,0,.15) !important;
    transform: translateY(-4px) !important;
  }

  .leaflet-popup-content-wrapper { border-radius: 12px !important; padding: 0 !important; box-shadow: 0 8px 24px rgba(0,0,0,.18) !important; }
  .leaflet-popup-content { margin: 0 !important; }
  .map-popup { padding: 10px 14px; min-width: 150px; }
  .map-popup-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: .06em; color: #002C2D; margin-bottom: 3px; }
  .map-popup-cat { font-family: 'Barlow', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: #B87333; }
</style>
