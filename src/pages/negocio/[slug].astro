---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { slug } = Astro.params;
const supabase  = Astro.locals.supabase;

// ── Fetch business ────────────────────────────────────────────────────────
const { data: biz, error: fetchError } = await supabase
  .from('businesses')
  .select('*, categories(name, slug), locations(name)')
  .eq('slug', slug)
  .eq('is_active', true)
  .single();

if (!biz || fetchError) return Astro.redirect('/');

// ── Ratings ───────────────────────────────────────────────────────────────
let avgRating = 0, totalReviews = 0;
try {
  const { data: r } = await supabase
    .from('business_ratings')
    .select('avg_rating, total_reviews')
    .eq('business_id', biz.id)
    .single();
  if (r) { avgRating = Math.round(parseFloat(r.avg_rating) * 10) / 10; totalReviews = r.total_reviews || 0; }
} catch {}

// ── Parse features_json ───────────────────────────────────────────────────
const fj             = (biz.features_json as any) ?? {};
const tags: string[] = fj.tags        ?? [];
const servicos       = fj.servicos     ?? [];
const horarios       = fj.horarios     ?? {};
const equipe         = fj.equipe       ?? [];
const listaExtra     = fj.lista_extra  ?? null;
const tipoServico    = fj.tipo_servico ?? '';
const faixaPreco     = fj.faixa_preco  ?? '';
const areasAtend     = fj.areas_atendimento ?? '';
const tempoResp      = fj.tempo_resposta    ?? '';
const garantia       = fj.garantia    ?? '';
const registroId     = fj.registro_id ?? '';
const clientes       = fj.clientes    ?? '';

const categoryName   = (biz.categories as any)?.name ?? '';
const categorySlug   = (biz.categories as any)?.slug ?? '';
const locationName   = (biz.locations  as any)?.name ?? '';

// ── Open/Closed status (Brasília timezone, server-side) ───────────────────
type Status = { open: boolean; badge: string; detail: string } | null;
function getStatus(): Status {
  if (!Object.keys(horarios).length) return null;
  const now  = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
  const day  = now.getDay();
  const time = now.getHours() + now.getMinutes() / 60;

  let sched: string | undefined;
  if      (day === 0) sched = horarios.domingo;
  else if (day === 6) sched = horarios.sabado;
  else                sched = horarios.seg_sex;

  if (!sched || sched.toLowerCase() === 'fechado')
    return { open: false, badge: 'Fechado', detail: 'Fechado hoje' };

  const m = sched.match(/(\d{1,2})h?\s*(?:–|-|às)\s*(\d{1,2})h?/i);
  if (!m) return { open: true, badge: 'Aberto', detail: sched };

  const [, oh, ch] = m;
  const openH = parseInt(oh), closeH = parseInt(ch);
  if (time >= openH && time < closeH)
    return { open: true,  badge: 'Aberto agora',  detail: `Fecha às ${ch}h` };
  return   { open: false, badge: 'Fechado agora', detail: time < openH ? `Abre às ${oh}h` : `Abre amanhã` };
}
const status = getStatus();

// ── CTA links ─────────────────────────────────────────────────────────────
const waNum     = (biz.whatsapp || biz.phone || '').replace(/\D/g, '');
const waUrl     = waNum ? `https://wa.me/55${waNum}?text=${encodeURIComponent(`Olá! Vi o perfil de *${biz.title}* no HubMetropolitano e gostaria de mais informações.`)}` : null;
const mapsUrl   = biz.address ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(biz.address + ' ' + locationName)}` : null;
const mapsEmbed = biz.address ? `https://maps.google.com/maps?q=${encodeURIComponent(biz.address + ' ' + locationName)}&output=embed` : null;
const websiteUrl = biz.website ? (biz.website.startsWith('http') ? biz.website : `https://${biz.website}`) : null;

// ── Gallery ───────────────────────────────────────────────────────────────
const gallery: string[] = [
  ...(biz.cover_url ? [biz.cover_url] : []),
  ...(Array.isArray(biz.images) ? biz.images.filter(Boolean) : []),
];

// ── Hours rows ────────────────────────────────────────────────────────────
const hourRows = [
  { label: 'Seg – Sex', value: horarios.seg_sex },
  { label: 'Sábado',    value: horarios.sabado  },
  { label: 'Domingo',   value: horarios.domingo },
].filter(h => h.value);

// ── Tabs visíveis ─────────────────────────────────────────────────────────
const hasSobre      = !!biz.description;
const hasServicos   = servicos.length > 0;
const hasHorarios   = hourRows.length > 0 || !!mapsEmbed;
const hasEquipe     = equipe.length > 0;
const hasComodidades = tags.length > 0 || (listaExtra?.itens?.length > 0);
const firstTab      = hasSobre ? 'sobre' : hasServicos ? 'servicos' : hasHorarios ? 'horarios' : 'sobre';

// ── Tag → SVG path ────────────────────────────────────────────────────────
const TAG_ICONS: Record<string, string> = {
  'Aceita reservas':        'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
  'Delivery disponível':    'M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  'Atendimento domiciliar': 'm2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  'Agendamento online':     'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  'Estacionamento':         'M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  'Wi-Fi gratuito':         'M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z',
  'Acessibilidade':         'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z',
  'Pet friendly':           'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z',
  'Aceita cartão':          'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z',
  'Aceita PIX':             'm3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
};

const pageTitle = `${biz.title}${categoryName ? ` — ${categoryName}` : ''} · HUBMETROPOLITANO`;
---

<Layout title={pageTitle} description={biz.description ?? biz.slogan ?? pageTitle}>
  <Fragment slot="head">
    {biz.cover_url && <meta property="og:image" content={biz.cover_url} />}
    <meta property="og:title"       content={biz.title} />
    <meta property="og:description" content={biz.slogan ?? biz.description ?? ''} />
    <meta property="og:type"        content="business.business" />
  </Fragment>

  <Header />

  <main class="bg-hub-gelo min-h-screen">

    <!-- ════════════════════════════════════════════════════════════
         HERO — Cover + identidade do negócio
    ════════════════════════════════════════════════════════════ -->
    <div class="relative bg-hub-pavao-profundo overflow-hidden" style="min-height: 62vh;">

      {/* Imagem de capa */}
      {gallery[0] && (
        <div class="absolute inset-0">
          <img
            src={gallery[0]}
            alt={biz.title}
            class="w-full h-full object-cover opacity-50"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      {/* Gradiente */}
      <div class="absolute inset-0 bg-gradient-to-t from-hub-pavao-profundo via-hub-pavao-profundo/60 to-hub-pavao-profundo/10 pointer-events-none" />

      {/* Voltar */}
      <div class="absolute top-6 left-0 right-0 z-10">
        <div class="container mx-auto px-4 lg:px-8">
          <a
            href={categorySlug ? `/${categorySlug}` : '/'}
            class="inline-flex items-center gap-1.5 font-body text-sm text-white/50 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            {categoryName || 'Início'}
          </a>
        </div>
      </div>

      {/* Identidade — parte inferior do hero */}
      <div class="relative z-10 container mx-auto px-4 lg:px-8 pb-10 pt-32">
        <div class="flex items-end gap-5">

          {/* Logo / avatar */}
          {biz.logo_url ? (
            <img
              src={biz.logo_url}
              alt={`Logo ${biz.title}`}
              class="w-20 h-20 lg:w-24 lg:h-24 rounded-2xl border-2 border-white/20 object-cover bg-white shadow-xl shrink-0"
              loading="lazy"
            />
          ) : (
            <div class="w-20 h-20 lg:w-24 lg:h-24 rounded-2xl border-2 border-white/20 bg-hub-pavao/80 flex items-center justify-center shadow-xl shrink-0">
              <span class="text-white font-head font-bold text-3xl">{biz.title.charAt(0)}</span>
            </div>
          )}

          {/* Nome + badges */}
          <div class="flex-1 min-w-0 pb-1">
            {/* Badges */}
            <div class="flex flex-wrap items-center gap-2 mb-2">
              {categoryName && (
                <span class="bg-hub-cobre text-white font-head font-semibold uppercase tracking-wider text-xs px-3 py-1 rounded-full">
                  {categoryName}
                </span>
              )}
              {tipoServico && (
                <span class="bg-white/15 backdrop-blur-sm text-white font-body text-xs px-3 py-1 rounded-full">
                  {tipoServico}
                </span>
              )}
              {status && (
                <span class={`inline-flex items-center gap-1.5 font-body text-xs font-semibold px-3 py-1 rounded-full ${status.open ? 'bg-emerald-500/90 text-white' : 'bg-red-500/80 text-white'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${status.open ? 'bg-white animate-pulse' : 'bg-white/60'}`}></span>
                  {status.badge}
                </span>
              )}
            </div>

            {/* Título */}
            <h1 class="text-white mb-1.5 normal-case tracking-normal leading-tight"
                style="font-family: var(--font-head); font-size: clamp(1.8rem, 4vw, 2.75rem); font-weight: 800;">
              {biz.title}
            </h1>

            {/* Slogan */}
            {biz.slogan && (
              <p class="font-body text-white/60 text-base leading-snug mb-3">{biz.slogan}</p>
            )}

            {/* Meta: localização, preço, rating */}
            <div class="flex flex-wrap items-center gap-4">
              {locationName && (
                <span class="inline-flex items-center gap-1.5 text-white/50 text-sm font-body">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0">
                    <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
                  </svg>
                  {locationName}
                </span>
              )}
              {faixaPreco && (
                <span class="inline-flex items-center gap-1 text-white/50 text-sm font-body">
                  <span class="font-semibold text-white/70">{faixaPreco}</span>
                </span>
              )}
              {totalReviews > 0 && (
                <span class="inline-flex items-center gap-1 text-white/50 text-sm font-body">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-yellow-400 shrink-0">
                    <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z" clip-rule="evenodd" />
                  </svg>
                  {avgRating} <span class="text-white/30">({totalReviews} {totalReviews === 1 ? 'avaliação' : 'avaliações'})</span>
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════
         BARRA DE AÇÕES RÁPIDAS
    ════════════════════════════════════════════════════════════ -->
    <div class="bg-white border-b border-hub-gelo shadow-sm sticky top-[72px] z-30">
      <div class="container mx-auto px-4 lg:px-8">
        <div class="flex items-center gap-2 py-3 overflow-x-auto scrollbar-none">

          {waUrl && (
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-head font-bold uppercase tracking-wide text-xs px-5 py-2.5 rounded-full transition-all active:scale-[.98] whitespace-nowrap shrink-0"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chamar no WhatsApp
            </a>
          )}

          {mapsUrl && (
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-hub-pavao text-hub-pavao hover:bg-hub-pavao hover:text-white font-head font-semibold uppercase tracking-wide text-xs px-4 py-2.5 rounded-full transition-all whitespace-nowrap shrink-0"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              Como Chegar
            </a>
          )}

          {biz.phone && (
            <a
              href={`tel:${biz.phone.replace(/\D/g,'')}`}
              class="inline-flex items-center gap-2 border border-hub-gelo bg-hub-gelo hover:border-hub-pavao text-hub-chumbo font-head font-semibold uppercase tracking-wide text-xs px-4 py-2.5 rounded-full transition-all whitespace-nowrap shrink-0"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              {biz.phone}
            </a>
          )}

          {websiteUrl && (
            <a
              href={websiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-hub-gelo bg-hub-gelo hover:border-hub-pavao text-hub-chumbo font-head font-semibold uppercase tracking-wide text-xs px-4 py-2.5 rounded-full transition-all whitespace-nowrap shrink-0"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253" />
              </svg>
              Site
            </a>
          )}

          {/* Status — alinhado à direita */}
          {status && (
            <div class={`ml-auto inline-flex items-center gap-2 font-body text-xs font-semibold px-4 py-2 rounded-full shrink-0 ${status.open ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-600'}`}>
              <span class={`w-2 h-2 rounded-full shrink-0 ${status.open ? 'bg-emerald-500 animate-pulse' : 'bg-red-400'}`}></span>
              {status.badge} · {status.detail}
            </div>
          )}

        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════
         CONTEÚDO PRINCIPAL + SIDEBAR
    ════════════════════════════════════════════════════════════ -->
    <div class="container mx-auto px-4 lg:px-8 py-8 lg:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10 items-start">

        <!-- ── COLUNA ESQUERDA: ABAS ────────────────────────────────── -->
        <div class="lg:col-span-2">

          <!-- Navegação das abas -->
          <div class="bg-white rounded-2xl shadow-sm mb-6 overflow-hidden">
            <nav id="tab-nav" class="flex overflow-x-auto scrollbar-none border-b border-hub-gelo">
              {hasSobre && (
                <button
                  data-tab="sobre"
                  class="tab-btn flex-1 min-w-max font-head font-semibold uppercase tracking-wide text-xs px-6 py-4 border-b-2 transition-colors whitespace-nowrap"
                  class:list={[firstTab === 'sobre' ? 'border-hub-cobre text-hub-cobre' : 'border-transparent text-hub-chumbo/40 hover:text-hub-chumbo']}
                >
                  Sobre
                </button>
              )}
              {hasServicos && (
                <button
                  data-tab="servicos"
