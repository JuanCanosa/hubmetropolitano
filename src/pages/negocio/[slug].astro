                    <div class="flex items-center justify-between">
                      <span class="font-body text-hub-chumbo/40 text-xs">Resposta</span>
                      <span class="font-body text-hub-chumbo text-xs">{tempoResp}</span>
                    </div>
                  )}
                  {clientes && (
                    <div class="flex items-center justify-between">
                      <span class="font-body text-hub-chumbo/40 text-xs">Clientes</span>
                      <span class="font-body text-hub-chumbo text-xs">{clientes}</span>
                    </div>
                  )}
                </div>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  // ── Tab switching ─────────────────────────────────────────────────────────
  const btns   = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  function activateTab(tabId: string) {
    btns.forEach(b => {
      const active = b.dataset.tab === tabId;
      b.classList.toggle('border-hub-cobre', active);
      b.classList.toggle('text-hub-cobre', active);
      b.classList.toggle('border-transparent', !active);
      b.classList.toggle('text-hub-chumbo/40', !active);
    });
    panels.forEach(p => {
      p.classList.toggle('hidden', p.id !== `tab-${tabId}`);
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.tab) activateTab(btn.dataset.tab);
    });
  });
</script>
