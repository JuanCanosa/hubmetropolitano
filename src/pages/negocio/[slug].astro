                      <div class="w-7 h-7 rounded-lg bg-hub-gelo flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-hub-pavao">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                        </svg>
                      </div>
                      <p class="font-body text-hub-chumbo/70 text-sm">{locationName}</p>
                    </div>
                  )}
                </div>
              )}

              <!-- Horários compacto (sidebar) -->
              {hourRows.length > 0 && (
                <div class="bg-white rounded-2xl shadow-sm p-5">
                  <p class="font-head font-bold uppercase tracking-widest text-xs text-hub-chumbo/30 mb-3">Horários</p>
                  <div class="flex flex-col gap-2">
                    {hourRows.map(h => (
                      <div class="flex items-center justify-between">
                        <span class="font-body text-hub-chumbo/50 text-xs">{h.label}</span>
                        <span class={`font-body text-xs font-semibold ${h.value?.toLowerCase() === 'fechado' ? 'text-red-400' : 'text-hub-chumbo'}`}>
                          {h.value}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

            </div>
          </aside>

        </div>
      </div>
    </div>

    <!-- ── CTA BANNER ─────────────────────────────────────────────────────── -->
    <section class="bg-hub-pavao py-14">
      <div class="container mx-auto px-4 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <h5 class="text-hub-cobre mb-2">Entre em contato</h5>
            <h2 class="text-white normal-case tracking-normal"
                style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; font-family: var(--font-head);">
              Fale com {biz.title}
            </h2>
            {biz.slogan && (
              <p class="font-body text-white/50 text-sm mt-1">{biz.slogan}</p>
            )}
          </div>
          <div class="flex flex-col sm:flex-row items-center gap-3 shrink-0">
            {waUrl && (
              <a
                href={waUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-head font-semibold uppercase tracking-wider text-sm px-7 py-4 rounded-full transition-colors active:scale-[.98]"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            )}
            {mapsUrl && (
              <a
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-head font-semibold uppercase tracking-wider text-sm px-7 py-4 rounded-full transition-colors border border-white/20"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                Como chegar
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
