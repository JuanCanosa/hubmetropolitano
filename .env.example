# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com → Project Settings → API

# URL do projeto (pública — pode ser exposta no front-end)
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anon/pública (pública — usada no front-end e SSR)
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Chave service role (SECRETA — nunca expor no front-end!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── WordPress / CMS ────────────────────────────────────────────────────────────
# URL do GraphQL (já hardcoded em src/lib/wordpress.ts — mover aqui quando conveniente)
# CMS_GRAPHQL_URL=https://cms.hubcentrometropolitano.com.br/graphql

# ── Site ───────────────────────────────────────────────────────────────────────
# PUBLIC_SITE_URL=https://hubcentrometropolitano.com.br
