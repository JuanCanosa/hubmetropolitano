{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/caminho/absoluto/para/o/projeto"
      ]
    },
    "ssh-mcp": {
      "command": "node",
      "args": ["/caminho/para/ssh-mcp/build/index.js"]
    },
    "wordpress-mcp": {
      "command": "node",
      "args": ["/caminho/para/wordpress-mcp/build/index.js"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "SEU_SUPABASE_ACCESS_TOKEN"]
    }
  }
}
